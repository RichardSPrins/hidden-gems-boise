---
// src/pages/explore/[category].astro
import PublicLayout from "@/layouts/PublicLayout.astro";
import { GET } from "@/pages/api/web/explore/category";

// ─── Category hero images (Unsplash placeholders) ─────────
const categoryHeroImages: Record<string, string> = {
  "food-and-drink":
    "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1600&auto=format&fit=crop&q=80",
  "health-and-wellness":
    "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=1600&auto=format&fit=crop&q=80",
  shopping:
    "https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?w=1600&auto=format&fit=crop&q=80",
  "home-services":
    "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&auto=format&fit=crop&q=80",
  "arts-and-entertainment":
    "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=1600&auto=format&fit=crop&q=80",
  "professional-services":
    "https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&auto=format&fit=crop&q=80",
  education:
    "https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1600&auto=format&fit=crop&q=80",
  automotive:
    "https://images.unsplash.com/photo-1487754180451-c456f719a1fc?w=1600&auto=format&fit=crop&q=80",
};

const categoryDescriptions: Record<string, string> = {
  "food-and-drink":
    "From specialty coffee to craft breweries, find the best places to eat and drink across the Treasure Valley.",
  "health-and-wellness":
    "Gyms, spas, salons, and wellness studios dedicated to helping you feel your best.",
  shopping:
    "Boutiques, vintage shops, bookstores, and local retailers worth exploring.",
  "home-services":
    "Trusted local contractors, cleaners, landscapers, and home professionals.",
  "arts-and-entertainment":
    "Galleries, venues, studios, and experiences that make Boise's creative scene shine.",
  "professional-services":
    "Local lawyers, accountants, marketers, and consultants serving the Treasure Valley.",
  education: "Learning centers, tutors, dance studios, martial arts, and more.",
  automotive:
    "Local shops for repairs, detailing, customization, and everything your vehicle needs.",
};

const categoryIcons: Record<string, string> = {
  "food-and-drink": "🍽️",
  "health-and-wellness": "💆",
  shopping: "🛍️",
  "home-services": "🔧",
  "arts-and-entertainment": "🎭",
  "professional-services": "💼",
  education: "📚",
  automotive: "🚗",
};

const priceMap: Record<string, string> = {
  ONE: "$",
  TWO: "$$",
  THREE: "$$$",
  FOUR: "$$$$",
};

const priceOptions = [
  { value: "ONE", label: "$" },
  { value: "TWO", label: "$$" },
  { value: "THREE", label: "$$$" },
  { value: "FOUR", label: "$$$$" },
];

// ─── URL Params ───────────────────────────────────────────
const { category: categoryParam } = Astro.params;
const url = new URL(Astro.request.url);
const q = url.searchParams.get("q") ?? "";
const subcategorySlug = url.searchParams.get("subcategory") ?? "";
const neighborhood = url.searchParams.get("neighborhood") ?? "";
const pricePoints = url.searchParams.getAll("price");
const sort = url.searchParams.get("sort") ?? "rating";
const page = Math.max(1, parseInt(url.searchParams.get("page") ?? "1"));

// ─── API Call ─────────────────────────────────────────────
const apiUrl = new URL(Astro.request.url);
apiUrl.searchParams.set("categorySlug", categoryParam ?? "");

const response = await GET({
  request: new Request(apiUrl.toString()),
  params: Astro.params,
} as any);
const data = await response.json();

if (data.notFound) {
  return Astro.redirect("/explore");
}

const {
  results,
  allCategories,
  activeCategory,
  neighborhoods,
  count,
  totalPages,
} = data;

const heroImage =
  categoryHeroImages[activeCategory.slug] ??
  "https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=1600&auto=format&fit=crop&q=80";
const heroDescription =
  categoryDescriptions[activeCategory.slug] ??
  `Discover the best ${activeCategory.name} businesses across the Treasure Valley.`;

// ─── Helpers ──────────────────────────────────────────────
function renderStars(rating: number) {
  const full = Math.floor(rating);
  const empty = 5 - full;
  return "★".repeat(full) + "☆".repeat(empty);
}

function buildUrl(overrides: Record<string, string | string[] | null>) {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (subcategorySlug) params.set("subcategory", subcategorySlug);
  if (neighborhood) params.set("neighborhood", neighborhood);
  pricePoints.forEach((p: string) => params.append("price", p));
  params.set("sort", sort);
  params.set("page", "1");
  Object.entries(overrides).forEach(([k, v]) => {
    params.delete(k);
    if (Array.isArray(v)) v.forEach((val) => params.append(k, val));
    else if (v !== null) params.set(k, v);
  });
  const base = `/explore/${activeCategory.slug}`;
  const qs = params.toString();
  return qs ? `${base}?${qs}` : base;
}

const hasFilters =
  q || subcategorySlug || neighborhood || pricePoints.length > 0;
---

<PublicLayout
  title={`${activeCategory.name} in Boise`}
  description={heroDescription}
>
  <!-- SLIM HERO -->
  <div class="explore-hero">
    <div
      class="explore-hero-bg"
      style={`background-image: url('${heroImage}')`}
    >
    </div>
    <div class="explore-hero-overlay"></div>
    <div class="explore-hero-content section-container">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/explore">Explore</a>
        <span>›</span>
        <span>{activeCategory.name}</span>
      </nav>
      <h1 class="explore-hero-title">
        {categoryIcons[activeCategory.slug] ?? "📍"}
        <em>{activeCategory.name}</em>
      </h1>
      <p class="explore-hero-sub">{heroDescription}</p>
    </div>
  </div>

  <!-- CATEGORY CAROUSEL -->
  <div class="cat-carousel-bar">
    <div class="cat-carousel-track">
      <a href="/explore" class="cat-pill">All</a>
      {
        allCategories.map((cat: any) => (
          <a
            href={`/explore/${cat.slug}`}
            class:list={[
              "cat-pill",
              cat.slug === activeCategory.slug && "cat-pill-active",
            ]}
          >
            <span>{categoryIcons[cat.slug] ?? "📍"}</span>
            {cat.name}
          </a>
        ))
      }
    </div>
  </div>

  <!-- SUBCATEGORY PILLS -->
  {
    activeCategory.subcategories.length > 0 && (
      <div class="subcat-bar section-container">
        <a
          href={buildUrl({ subcategory: null })}
          class:list={["subcat-pill", !subcategorySlug && "subcat-pill-active"]}
        >
          All {activeCategory.name}
        </a>
        {activeCategory.subcategories.map((sub: any) => (
          <a
            href={buildUrl({ subcategory: sub.slug })}
            class:list={[
              "subcat-pill",
              subcategorySlug === sub.slug && "subcat-pill-active",
            ]}
          >
            {sub.name}
          </a>
        ))}
      </div>
    )
  }

  <!-- MAIN LAYOUT -->
  <div class="explore-layout section-container">
    <!-- SIDEBAR -->
    <aside class="explore-sidebar">
      <div class="sidebar-inner">
        <form
          method="get"
          action={`/explore/${activeCategory.slug}`}
          class="sidebar-section"
        >
          <label class="sidebar-label">Search</label>
          <div class="sidebar-search-row">
            <input
              type="text"
              name="q"
              value={q}
              placeholder="Keywords…"
              class="gem-input sidebar-search-input"
            />
            <input type="hidden" name="sort" value={sort} />
            <button type="submit" class="sidebar-search-btn">Go</button>
          </div>
        </form>

        <div class="sidebar-divider"></div>

        {
          activeCategory.subcategories.length > 0 && (
            <>
              <div class="sidebar-section">
                <p class="sidebar-label">Type</p>
                <ul class="sidebar-cat-list">
                  <li>
                    <a
                      href={buildUrl({ subcategory: null })}
                      class:list={[
                        "sidebar-cat-item",
                        !subcategorySlug && "sidebar-cat-active",
                      ]}
                    >
                      All {activeCategory.name}
                    </a>
                  </li>
                  {activeCategory.subcategories.map((sub: any) => (
                    <li>
                      <a
                        href={buildUrl({ subcategory: sub.slug })}
                        class:list={[
                          "sidebar-cat-item",
                          subcategorySlug === sub.slug && "sidebar-cat-active",
                        ]}
                      >
                        {sub.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="sidebar-divider" />
            </>
          )
        }

        <div class="sidebar-section">
          <p class="sidebar-label">Browse Categories</p>
          <ul class="sidebar-cat-list">
            {
              allCategories.map((cat: any) => (
                <li>
                  <a
                    href={`/explore/${cat.slug}`}
                    class:list={[
                      "sidebar-cat-item",
                      cat.slug === activeCategory.slug && "sidebar-cat-active",
                    ]}
                  >
                    <span class="sidebar-cat-icon">
                      {categoryIcons[cat.slug] ?? "📍"}
                    </span>
                    {cat.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="sidebar-divider"></div>

        <form
          method="get"
          action={`/explore/${activeCategory.slug}`}
          class="sidebar-section"
        >
          <p class="sidebar-label">Price Range</p>
          <input type="hidden" name="q" value={q} />
          <input type="hidden" name="subcategory" value={subcategorySlug} />
          <input type="hidden" name="sort" value={sort} />
          <div class="price-pills">
            {
              priceOptions.map((opt) => (
                <label
                  class:list={[
                    "price-pill",
                    pricePoints.includes(opt.value) && "price-pill-active",
                  ]}
                >
                  <input
                    type="checkbox"
                    name="price"
                    value={opt.value}
                    checked={pricePoints.includes(opt.value)}
                    class="sr-only"
                    onchange="this.form.submit()"
                  />
                  {opt.label}
                </label>
              ))
            }
          </div>
        </form>

        {
          neighborhoods.length > 0 && (
            <>
              <div class="sidebar-divider" />
              <div class="sidebar-section">
                <p class="sidebar-label">Neighborhood</p>
                <ul class="sidebar-neighborhood-list">
                  <li>
                    <a
                      href={buildUrl({ neighborhood: null })}
                      class:list={[
                        "sidebar-neighborhood-item",
                        !neighborhood && "sidebar-neighborhood-active",
                      ]}
                    >
                      All Neighborhoods
                    </a>
                  </li>
                  {neighborhoods.map((n: string) => (
                    <li>
                      <a
                        href={buildUrl({ neighborhood: n })}
                        class:list={[
                          "sidebar-neighborhood-item",
                          neighborhood === n && "sidebar-neighborhood-active",
                        ]}
                      >
                        {n}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </>
          )
        }

        {
          hasFilters && (
            <>
              <div class="sidebar-divider" />
              <div class="sidebar-section">
                <a
                  href={`/explore/${activeCategory.slug}`}
                  class="sidebar-clear"
                >
                  ✕ Clear filters
                </a>
              </div>
            </>
          )
        }
      </div>
    </aside>

    <!-- RESULTS -->
    <div class="explore-results">
      <div class="results-header">
        <p class="results-count">
          {Number(count).toLocaleString()}
          {Number(count) === 1 ? "result" : "results"}
          {
            subcategorySlug && (
              <span>
                {" "}
                in{" "}
                <strong>
                  {
                    activeCategory.subcategories.find(
                      (s: any) => s.slug === subcategorySlug
                    )?.name
                  }
                </strong>
              </span>
            )
          }
          {
            q && (
              <span>
                {" "}
                for "<strong>{q}</strong>"
              </span>
            )
          }
        </p>
        <div class="results-controls">
          <button
            class="mobile-filter-btn"
            id="mobile-filter-btn"
            aria-label="Open filters"
          >
            ⚙ Filters {hasFilters && <span class="filter-dot" />}
          </button>
          <form method="get" action={`/explore/${activeCategory.slug}`}>
            <input type="hidden" name="q" value={q} />
            <input type="hidden" name="subcategory" value={subcategorySlug} />
            <input type="hidden" name="neighborhood" value={neighborhood} />
            {
              pricePoints.map((p: string) => (
                <input type="hidden" name="price" value={p} />
              ))
            }
            <select
              name="sort"
              class="sort-select"
              onchange="this.form.submit()"
            >
              <option value="rating" selected={sort === "rating"}
                >Top Rated</option
              >
              <option value="newest" selected={sort === "newest"}>Newest</option
              >
              <option value="az" selected={sort === "az"}>A–Z</option>
            </select>
          </form>
        </div>
      </div>

      {
        hasFilters && (
          <div class="filter-chips">
            {q && (
              <a href={buildUrl({ q: null })} class="filter-chip">
                "{q}" ✕
              </a>
            )}
            {subcategorySlug && (
              <a href={buildUrl({ subcategory: null })} class="filter-chip">
                {
                  activeCategory.subcategories.find(
                    (s: any) => s.slug === subcategorySlug
                  )?.name
                }{" "}
                ✕
              </a>
            )}
            {neighborhood && (
              <a href={buildUrl({ neighborhood: null })} class="filter-chip">
                {neighborhood} ✕
              </a>
            )}
            {pricePoints.map((p: string) => (
              <a
                href={buildUrl({
                  price: pricePoints.filter((x: string) => x !== p),
                })}
                class="filter-chip"
              >
                {priceMap[p]} ✕
              </a>
            ))}
          </div>
        )
      }

      {
        results.length > 0 ? (
          <ul class="biz-list">
            {results.map((biz: any) => (
              <li>
                <a href={`/listings/${biz.slug}`} class="biz-list-card">
                  <div class="biz-list-img">
                    {biz.images[0] ? (
                      <img
                        src={biz.images[0].url}
                        alt={biz.images[0].alt ?? biz.name}
                        loading="lazy"
                      />
                    ) : (
                      <span class="biz-list-img-placeholder">
                        {categoryIcons[biz.category.name] ?? "📍"}
                      </span>
                    )}
                    {biz.isGemOfWeek && (
                      <span class="biz-list-gem-badge">💎 Gem</span>
                    )}
                  </div>
                  <div class="biz-list-body">
                    <div class="biz-list-row-1">
                      <span class="biz-card-cat">{biz.category.name}</span>
                      {biz.subcategory && (
                        <span class="biz-list-subcat">
                          · {biz.subcategory.name}
                        </span>
                      )}
                    </div>
                    <div class="biz-list-row-2">
                      <h2 class="biz-list-name">{biz.name}</h2>
                      {biz.reviewCount > 0 && (
                        <div class="biz-list-rating">
                          <span class="biz-list-stars">
                            {renderStars(biz.averageRating)}
                          </span>
                          <span class="biz-list-rating-num">
                            {biz.averageRating.toFixed(1)}
                          </span>
                          <span class="biz-list-rating-count">
                            ({biz.reviewCount})
                          </span>
                        </div>
                      )}
                    </div>
                    <div class="biz-list-row-3">
                      {biz.pricePoint && (
                        <span class="biz-list-price">
                          {priceMap[biz.pricePoint]}
                        </span>
                      )}
                      {biz.locations[0]?.neighborhood && (
                        <span class="biz-list-location">
                          📍 {biz.locations[0].neighborhood}, Boise
                        </span>
                      )}
                    </div>
                    {biz.bio && (
                      <p class="biz-list-bio">
                        {biz.bio.length > 160
                          ? biz.bio.slice(0, 157) + "…"
                          : biz.bio}
                      </p>
                    )}
                    <div class="biz-list-footer">
                      <div class="biz-list-tags">
                        {biz.isVerified && (
                          <span class="verified-badge">✓ Verified</span>
                        )}
                      </div>
                      <span class="biz-list-cta">View →</span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <div class="no-results">
            <p class="no-results-icon">🔍</p>
            <h3 class="no-results-title">No results found</h3>
            <p class="no-results-sub">
              Try adjusting your filters or search terms.
            </p>
            <a href={`/explore/${activeCategory.slug}`} class="btn-gold">
              Clear Filters
            </a>
          </div>
        )
      }

      {
        totalPages > 1 && (
          <div class="explore-pagination">
            {page > 1 && (
              <a href={buildUrl({ page: String(page - 1) })} class="page-btn">
                ← Previous
              </a>
            )}
            <div class="page-numbers">
              {Array.from(
                { length: totalPages },
                (_: any, i: number) => i + 1
              ).map((p: number) => (
                <a
                  href={buildUrl({ page: String(p) })}
                  class:list={["page-num", p === page && "page-num-active"]}
                >
                  {p}
                </a>
              ))}
            </div>
            {page < totalPages && (
              <a href={buildUrl({ page: String(page + 1) })} class="page-btn">
                Next →
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer-overlay hidden" id="drawer-overlay"></div>
  <div class="mobile-drawer hidden" id="mobile-drawer" aria-hidden="true">
    <div class="mobile-drawer-header">
      <h2 class="mobile-drawer-title">Filters</h2>
      <button class="mobile-drawer-close" id="drawer-close" aria-label="Close"
        >✕</button
      >
    </div>
    <div class="mobile-drawer-body">
      <form
        method="get"
        action={`/explore/${activeCategory.slug}`}
        class="sidebar-section"
      >
        <label class="sidebar-label">Search</label>
        <div class="sidebar-search-row">
          <input
            type="text"
            name="q"
            value={q}
            placeholder="Keywords…"
            class="gem-input"
          />
          <input type="hidden" name="sort" value={sort} />
          <button type="submit" class="sidebar-search-btn">Go</button>
        </div>
      </form>
      <div class="sidebar-divider"></div>
      {
        activeCategory.subcategories.length > 0 && (
          <>
            <div class="sidebar-section">
              <p class="sidebar-label">Type</p>
              <ul class="sidebar-cat-list">
                <li>
                  <a
                    href={buildUrl({ subcategory: null })}
                    class:list={[
                      "sidebar-cat-item",
                      !subcategorySlug && "sidebar-cat-active",
                    ]}
                  >
                    All {activeCategory.name}
                  </a>
                </li>
                {activeCategory.subcategories.map((sub: any) => (
                  <li>
                    <a
                      href={buildUrl({ subcategory: sub.slug })}
                      class:list={[
                        "sidebar-cat-item",
                        subcategorySlug === sub.slug && "sidebar-cat-active",
                      ]}
                    >
                      {sub.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
            <div class="sidebar-divider" />
          </>
        )
      }
      <form
        method="get"
        action={`/explore/${activeCategory.slug}`}
        class="sidebar-section"
      >
        <p class="sidebar-label">Price Range</p>
        <input type="hidden" name="q" value={q} />
        <input type="hidden" name="subcategory" value={subcategorySlug} />
        <input type="hidden" name="sort" value={sort} />
        <div class="price-pills">
          {
            priceOptions.map((opt) => (
              <label
                class:list={[
                  "price-pill",
                  pricePoints.includes(opt.value) && "price-pill-active",
                ]}
              >
                <input
                  type="checkbox"
                  name="price"
                  value={opt.value}
                  checked={pricePoints.includes(opt.value)}
                  class="sr-only"
                  onchange="this.form.submit()"
                />
                {opt.label}
              </label>
            ))
          }
        </div>
      </form>
      {
        hasFilters && (
          <div class="sidebar-section">
            <a href={`/explore/${activeCategory.slug}`} class="sidebar-clear">
              ✕ Clear filters
            </a>
          </div>
        )
      }
    </div>
  </div>
</PublicLayout>

<style>
  .explore-hero {
    position: relative;
    height: 300px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-top: 4rem;
  }

  .explore-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
  }

  .explore-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 13, 0.35) 0%,
      rgba(13, 13, 13, 0.78) 100%
    );
  }

  .explore-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 2.5rem;
    width: 100%;
  }

  .hero-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
  }

  .hero-breadcrumb a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.15s;
  }
  .hero-breadcrumb a:hover {
    color: var(--color-gem-gold);
  }

  .explore-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 600;
    color: white;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .explore-hero-title em {
    font-style: italic;
    color: var(--color-gem-gold-light);
  }
  .explore-hero-sub {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.9375rem;
    max-width: 560px;
  }

  .cat-carousel-bar {
    background: white;
    border-bottom: 1px solid var(--color-gem-border);
    overflow-x: auto;
    scrollbar-width: none;
    position: sticky;
    top: 64px;
    z-index: 40;
  }

  .cat-carousel-bar::-webkit-scrollbar {
    display: none;
  }

  .cat-carousel-track {
    display: flex;
    gap: 0.375rem;
    padding: 0.75rem 2rem;
    width: max-content;
    min-width: 100%;
  }

  .cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    border: 1.5px solid var(--color-gem-border);
