---
// src/pages/explore/index.astro
import PublicLayout from "@/layouts/PublicLayout.astro";
import { GET } from "@/pages/api/web/explore";

const response = await GET(Astro);
const { results, allCategories, neighborhoods, count, page, totalPages } = await response.json();


// ─── URL Params ───────────────────────────────────────────
const url = new URL(Astro.request.url);
const q = url.searchParams.get("q") ?? "";
const categorySlug = url.searchParams.get("category") ?? "";
const subcategorySlug = url.searchParams.get("subcategory") ?? "";
const neighborhood = url.searchParams.get("neighborhood") ?? "";
const pricePoints = url.searchParams.getAll("price");
const features = url.searchParams.getAll("feature");
const sort = url.searchParams.get("sort") ?? "rating";


const activeCategory = categorySlug
  ? allCategories.find(c => c.slug === categorySlug)
  : null;


const priceOptions = [
  { value: "ONE", label: "$" },
  { value: "TWO", label: "$$" },
  { value: "THREE", label: "$$$" },
  { value: "FOUR", label: "$$$$" },
];

const categoryIcons: Record<string, string> = {
  "Food & Drink": "🍽️",
  "Health & Wellness": "💆",
  "Shopping": "🛍️",
  "Home Services": "🔧",
  "Arts & Entertainment": "🎭",
  "Professional Services": "💼",
  "Education": "📚",
  "Automotive": "🚗",
};

const priceMap: Record<string, string> = {
  ONE: "$", TWO: "$$", THREE: "$$$", FOUR: "$$$$",
};

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const empty = 5 - full;
  return "★".repeat(full) + "☆".repeat(empty);
}

function buildUrl(overrides: Record<string, string | string[] | null>) {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (categorySlug) params.set("category", categorySlug);
  if (subcategorySlug) params.set("subcategory", subcategorySlug);
  if (neighborhood) params.set("neighborhood", neighborhood);
  pricePoints.forEach(p => params.append("price", p));
  features.forEach(f => params.append("feature", f));
  params.set("sort", sort);
  params.set("page", "1");
  Object.entries(overrides).forEach(([k, v]) => {
    params.delete(k);
    if (Array.isArray(v)) v.forEach(val => params.append(k, val));
    else if (v !== null) params.set(k, v);
  });
  return `/explore?${params.toString()}`;
}

const hasFilters = q || categorySlug || subcategorySlug || neighborhood || pricePoints.length > 0;
---

<PublicLayout
  title={activeCategory ? `${activeCategory.name} in Boise` : "Explore Local Businesses"}
  description="Discover the best independently owned businesses across the Treasure Valley."
>
  <!-- SLIM HERO -->
  <div class="explore-hero">
    <div class="explore-hero-bg"></div>
    <div class="explore-hero-overlay"></div>
    <div class="explore-hero-content section-container">
      <p class="section-eyebrow" style="color: var(--color-gem-gold-light)">Treasure Valley Directory</p>
      <h1 class="explore-hero-title">
        {activeCategory ? activeCategory.name : "Explore"} <em>Local Gems</em>
      </h1>
      <p class="explore-hero-sub">
        {Number(count).toLocaleString()} independently owned {Number(count) === 1 ? "business" : "businesses"} across Boise and the Treasure Valley
      </p>
    </div>
  </div>

  <!-- CATEGORY CAROUSEL -->
  <div class="cat-carousel-bar">
    <div class="cat-carousel-track">
      <a
        href="/explore"
        class:list={["cat-pill", !categorySlug && "cat-pill-active"]}
      >
        All
      </a>
      {allCategories.map(cat => (
        <a
          href={`/explore/${cat.slug}`}
          class:list={["cat-pill", categorySlug === cat.slug && "cat-pill-active"]}
        >
          <span>{categoryIcons[cat.name] ?? "📍"}</span>
          {cat.name}
        </a>
      ))}
    </div>
  </div>

  <!-- MAIN LAYOUT -->
  <div class="explore-layout section-container">

    <!-- SIDEBAR -->
    <aside class="explore-sidebar" id="explore-sidebar">
      <div class="sidebar-inner">

        <!-- Search -->
        <form method="get" action="/explore" class="sidebar-section">
          <label class="sidebar-label">Search</label>
          <div class="sidebar-search-row">
            <input
              type="text"
              name="q"
              value={q}
              placeholder="Keywords…"
              class="gem-input sidebar-search-input"
            />
            <input type="hidden" name="category" value={categorySlug} />
            <input type="hidden" name="sort" value={sort} />
            <button type="submit" class="sidebar-search-btn">Go</button>
          </div>
        </form>

        <div class="sidebar-divider"></div>

        <!-- Categories -->
        <div class="sidebar-section">
          <p class="sidebar-label">Category</p>
          <ul class="sidebar-cat-list">
            <li>
              <a
                href={buildUrl({ category: null, subcategory: null, page: "1" })}
                class:list={["sidebar-cat-item", !categorySlug && "sidebar-cat-active"]}
              >
                All Categories
              </a>
            </li>
            {allCategories.map(cat => (
              <li>
                <a
                  href={buildUrl({ category: cat.slug, subcategory: null, page: "1" })}
                  class:list={["sidebar-cat-item", categorySlug === cat.slug && "sidebar-cat-active"]}
                >
                  <span class="sidebar-cat-icon">{categoryIcons[cat.name] ?? "📍"}</span>
                  {cat.name}
                </a>
                {categorySlug === cat.slug && cat.subcategories.length > 0 && (
                  <ul class="sidebar-subcat-list">
                    <li>
                      <a
                        href={buildUrl({ subcategory: null, page: "1" })}
                        class:list={["sidebar-subcat-item", !subcategorySlug && "sidebar-subcat-active"]}
                      >
                        All {cat.name}
                      </a>
                    </li>
                    {cat.subcategories.map(sub => (
                      <li>
                        <a
                          href={buildUrl({ subcategory: sub.slug, page: "1" })}
                          class:list={["sidebar-subcat-item", subcategorySlug === sub.slug && "sidebar-subcat-active"]}
                        >
                          {sub.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-divider"></div>

        <!-- Price Point -->
        <form method="get" action="/explore" class="sidebar-section" id="price-form">
          <p class="sidebar-label">Price Range</p>
          <input type="hidden" name="q" value={q} />
          <input type="hidden" name="category" value={categorySlug} />
          <input type="hidden" name="subcategory" value={subcategorySlug} />
          <input type="hidden" name="sort" value={sort} />
          <div class="price-pills">
            {priceOptions.map(opt => (
              <label class:list={["price-pill", pricePoints.includes(opt.value) && "price-pill-active"]}>
                <input
                  type="checkbox"
                  name="price"
                  value={opt.value}
                  checked={pricePoints.includes(opt.value)}
                  class="sr-only"
                  onchange="this.form.submit()"
                />
                {opt.label}
              </label>
            ))}
          </div>
        </form>

        <div class="sidebar-divider"></div>

        <!-- Neighborhood -->
        {neighborhoods.length > 0 && (
          <div class="sidebar-section">
            <p class="sidebar-label">Neighborhood</p>
            <ul class="sidebar-neighborhood-list">
              <li>
                <a
                  href={buildUrl({ neighborhood: null, page: "1" })}
                  class:list={["sidebar-neighborhood-item", !neighborhood && "sidebar-neighborhood-active"]}
                >
                  All Neighborhoods
                </a>
              </li>
              {neighborhoods.map(n => (
                <li>
                  <a
                    href={buildUrl({ neighborhood: n, page: "1" })}
                    class:list={["sidebar-neighborhood-item", neighborhood === n && "sidebar-neighborhood-active"]}
                  >
                    {n}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {hasFilters && (
          <>
            <div class="sidebar-divider"></div>
            <div class="sidebar-section">
              <a href="/explore" class="sidebar-clear">
                ✕ Clear all filters
              </a>
            </div>
          </>
        )}
      </div>
    </aside>

    <!-- RESULTS -->
    <div class="explore-results">

      <!-- Results header -->
      <div class="results-header">
        <p class="results-count">
          {Number(count).toLocaleString()} {Number(count) === 1 ? "result" : "results"}
          {q && <span> for "<strong>{q}</strong>"</span>}
          {activeCategory && <span> in <strong>{activeCategory.name}</strong></span>}
        </p>

        <div class="results-controls">
          <!-- Mobile filter toggle -->
          <button
            class="mobile-filter-btn lg:hidden"
            id="mobile-filter-btn"
            aria-label="Open filters"
          >
            ⚙ Filters {hasFilters && <span class="filter-dot"></span>}
          </button>

          <!-- Sort -->
          <form method="get" action="/explore" id="sort-form">
            <input type="hidden" name="q" value={q} />
            <input type="hidden" name="category" value={categorySlug} />
            <input type="hidden" name="subcategory" value={subcategorySlug} />
            <input type="hidden" name="neighborhood" value={neighborhood} />
            {pricePoints.map(p => <input type="hidden" name="price" value={p} />)}
            <select
              name="sort"
              class="sort-select"
              onchange="this.form.submit()"
            >
              <option value="rating" selected={sort === "rating"}>Top Rated</option>
              <option value="newest" selected={sort === "newest"}>Newest</option>
              <option value="az" selected={sort === "az"}>A–Z</option>
            </select>
          </form>
        </div>
      </div>

      <!-- Active filter chips -->
      {hasFilters && (
        <div class="filter-chips">
          {q && (
            <a href={buildUrl({ q: null })} class="filter-chip">
              "{q}" ✕
            </a>
          )}
          {categorySlug && activeCategory && (
            <a href={buildUrl({ category: null, subcategory: null })} class="filter-chip">
              {activeCategory.name} ✕
            </a>
          )}
          {subcategorySlug && activeCategory && (
            <a href={buildUrl({ subcategory: null })} class="filter-chip">
              {activeCategory.subcategories.find(s => s.slug === subcategorySlug)?.name} ✕
            </a>
          )}
          {neighborhood && (
            <a href={buildUrl({ neighborhood: null })} class="filter-chip">
              {neighborhood} ✕
            </a>
          )}
          {pricePoints.map(p => (
            <a
              href={buildUrl({ price: pricePoints.filter(x => x !== p) })}
              class="filter-chip"
            >
              {priceMap[p]} ✕
            </a>
          ))}
        </div>
      )}

      <!-- Business list -->
      {results.length > 0 ? (
        <ul class="biz-list">
          {results.map(biz => (
            <li>
                <a href={`/listings/${biz.slug}`} class="biz-list-card">
                    <div class="biz-list-img">
                        {biz.images[0] ? (
                        <img src={biz.images[0].url} alt={biz.images[0].alt ?? biz.name} loading="lazy" />
                        ) : (
                        <span class="biz-list-img-placeholder">{categoryIcons[biz.category.name] ?? "📍"}</span>
                        )}
                        {biz.isGemOfWeek && <span class="biz-list-gem-badge">💎 Gem</span>}
                    </div>

                    <div class="biz-list-body">
                        <!-- Row 1: Category · Subcategory -->
                        <div class="biz-list-row-1">
                        <span class="biz-card-cat">{biz.category.name}</span>
                        {biz.subcategory && (
                            <span class="biz-list-subcat">· {biz.subcategory.name}</span>
                        )}
                        </div>

                        <!-- Row 2: Name + Rating -->
                        <div class="biz-list-row-2">
                        <h2 class="biz-list-name">{biz.name}</h2>
                        {biz.reviewCount > 0 && (
                            <div class="biz-list-rating">
                            <span class="biz-list-stars">{renderStars(biz.averageRating)}</span>
                            <span class="biz-list-rating-num">{biz.averageRating.toFixed(1)}</span>
                            <span class="biz-list-rating-count">({biz.reviewCount})</span>
                            </div>
                        )}
                        </div>

                        <!-- Row 3: Price + Location -->
                        <div class="biz-list-row-3">
                        {biz.pricePoint && (
                            <span class="biz-list-price">{priceMap[biz.pricePoint]}</span>
                        )}
                        {biz.locations[0]?.neighborhood && (
                            <span class="biz-list-location">
                            📍 {biz.locations[0].neighborhood}, Boise
                            </span>
                        )}
                        </div>

                        <!-- Bio -->
                        {biz.bio && (
                        <p class="biz-list-bio">
                            {biz.bio.length > 160 ? biz.bio.slice(0, 157) + "…" : biz.bio}
                        </p>
                        )}

                        <!-- Footer -->
                        <div class="biz-list-footer">
                        <div class="biz-list-tags">
                            {biz.isVerified && <span class="verified-badge">✓ Verified</span>}
                        </div>
                        <span class="biz-list-cta">View →</span>
                        </div>
                    </div>
                </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="no-results">
          <p class="no-results-icon">🔍</p>
          <h3 class="no-results-title">No results found</h3>
          <p class="no-results-sub">Try adjusting your filters or search terms.</p>
          <a href="/explore" class="btn-gold">Clear Filters</a>
        </div>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <div class="explore-pagination">
          {page > 1 && (
            <a href={buildUrl({ page: String(page - 1) })} class="page-btn">← Previous</a>
          )}
          <div class="page-numbers">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
              <a
                href={buildUrl({ page: String(p) })}
                class:list={["page-num", p === page && "page-num-active"]}
              >
                {p}
              </a>
            ))}
          </div>
          {page < totalPages && (
            <a href={buildUrl({ page: String(page + 1) })} class="page-btn">Next →</a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Mobile filter drawer -->
  <div class="mobile-drawer-overlay hidden" id="drawer-overlay"></div>
  <div class="mobile-drawer hidden" id="mobile-drawer" aria-hidden="true">
    <div class="mobile-drawer-header">
      <h2 class="mobile-drawer-title">Filters</h2>
      <button class="mobile-drawer-close" id="drawer-close" aria-label="Close filters">✕</button>
    </div>
    <div class="mobile-drawer-body">

      <!-- Search -->
      <form method="get" action="/explore" class="sidebar-section">
        <label class="sidebar-label">Search</label>
        <div class="sidebar-search-row">
          <input type="text" name="q" value={q} placeholder="Keywords…" class="gem-input" />
          <input type="hidden" name="category" value={categorySlug} />
          <input type="hidden" name="sort" value={sort} />
          <button type="submit" class="sidebar-search-btn">Go</button>
        </div>
      </form>

      <div class="sidebar-divider"></div>

      <!-- Categories -->
      <div class="sidebar-section">
        <p class="sidebar-label">Category</p>
        <ul class="sidebar-cat-list">
          <li>
            <a href="/explore" class:list={["sidebar-cat-item", !categorySlug && "sidebar-cat-active"]}>
              All Categories
            </a>
          </li>
          {allCategories.map(cat => (
            <li>
              <a
                href={`/explore/${cat.slug}`}
                class:list={["sidebar-cat-item", categorySlug === cat.slug && "sidebar-cat-active"]}
              >
                <span class="sidebar-cat-icon">{categoryIcons[cat.name] ?? "📍"}</span>
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="sidebar-divider"></div>

      <!-- Price -->
      <form method="get" action="/explore" class="sidebar-section">
        <p class="sidebar-label">Price Range</p>
        <input type="hidden" name="q" value={q} />
        <input type="hidden" name="category" value={categorySlug} />
        <input type="hidden" name="sort" value={sort} />
        <div class="price-pills">
          {priceOptions.map(opt => (
            <label class:list={["price-pill", pricePoints.includes(opt.value) && "price-pill-active"]}>
              <input
                type="checkbox"
                name="price"
                value={opt.value}
                checked={pricePoints.includes(opt.value)}
                class="sr-only"
                onchange="this.form.submit()"
              />
              {opt.label}
            </label>
          ))}
        </div>
      </form>

      {hasFilters && (
        <div class="sidebar-section mt-4">
          <a href="/explore" class="sidebar-clear">✕ Clear all filters</a>
        </div>
      )}
    </div>
  </div>
</PublicLayout>

<style>
  /* ── HERO ── */
  .explore-hero {
    position: relative;
    height: 280px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-top: 0;
    padding-top: 4rem;
  }

  .explore-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=1600&auto=format&fit=crop&q=80');
    background-size: cover;
    background-position: center 40%;
  }

  .explore-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13,13,13,0.4) 0%,
      rgba(13,13,13,0.75) 100%
    );
  }

  .explore-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 2.5rem;
    width: 100%;
  }

  .explore-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 600;
    color: white;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .explore-hero-title em {
    font-style: italic;
    color: var(--color-gem-gold-light);
  }

  .explore-hero-sub {
    color: rgba(255,255,255,0.65);
    font-size: 0.9375rem;
  }

  /* ── CATEGORY CAROUSEL BAR ── */
  .cat-carousel-bar {
    background: white;
    border-bottom: 1px solid var(--color-gem-border);
    overflow-x: auto;
    scrollbar-width: none;
    position: sticky;
    top: 64px;
    z-index: 40;
  }

  .cat-carousel-bar::-webkit-scrollbar { display: none; }

  .cat-carousel-track {
    display: flex;
    gap: 0.375rem;
    padding: 0.75rem 2rem;
    width: max-content;
    min-width: 100%;
  }

  .cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    border: 1.5px solid var(--color-gem-border);
    color: var(--color-gem-text-muted);
    background: white;
    transition: all 0.15s;
  }

  .cat-pill:hover {
    border-color: var(--color-gem-gold);
    color: var(--color-gem-gold);
  }

  .cat-pill-active {
    background: var(--color-gem-gold);
    border-color: var(--color-gem-gold);
    color: var(--color-gem-dark);
    font-weight: 600;
  }

  /* ── LAYOUT ── */
  .explore-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
    padding-top: 2rem;
    padding-bottom: 4rem;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .explore-layout {
      grid-template-columns: 1fr;
    }
    .explore-sidebar {
      display: none;
    }
  }

  /* ── SIDEBAR ── */
  .explore-sidebar {
    position: sticky;
    top: 120px;
  }

  .sidebar-inner {
    background: white;
    border-radius: 12px;
    border: 1.5px solid var(--color-gem-border);
    overflow: hidden;
  }

  .sidebar-section {
    padding: 1.25rem;
  }

  .sidebar-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gem-text-subtle);
    margin-bottom: 0.75rem;
  }

  .sidebar-divider {
    height: 1px;
    background: var(--color-gem-border);
  }

  .sidebar-search-row {
    display: flex;
    gap: 0.5rem;
  }

  .sidebar-search-input {
    flex: 1;
    font-size: 0.875rem;
    padding: 0.625rem 0.875rem;
  }

  .sidebar-search-btn {
    padding: 0.625rem 0.875rem;
    background: var(--color-gem-gold);
    color: var(--color-gem-dark);
    border: none;
    border-radius: 8px;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .sidebar-search-btn:hover { background: var(--color-gem-gold-light); }

  .sidebar-cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .sidebar-cat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gem-text-muted);
    text-decoration: none;
    transition: all 0.15s;
  }

  .sidebar-cat-item:hover {
    background: var(--color-gem-mist);
    color: var(--color-gem-text);
  }

  .sidebar-cat-active {
    background: rgba(201,168,76,0.08);
    color: var(--color-gem-gold);
    font-weight: 600;
  }

  .sidebar-cat-icon { font-size: 1rem; }

  .sidebar-subcat-list {
    list-style: none;
    margin: 0.25rem 0 0.25rem 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    border-left: 2px solid var(--color-gem-border);
    padding-left: 0.75rem;
  }

  .sidebar-subcat-item {
    display: block;
    padding: 0.375rem 0.5rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: var(--color-gem-text-muted);
    text-decoration: none;
    transition: all 0.15s;
  }

  .sidebar-subcat-item:hover { color: var(--color-gem-text); }
  .sidebar-subcat-active { color: var(--color-gem-gold); font-weight: 600; }

  .price-pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .price-pill {
    padding: 0.375rem 0.875rem;
    border-radius: 100px;
    border: 1.5px solid var(--color-gem-border);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gem-text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .price-pill:hover { border-color: var(--color-gem-gold); color: var(--color-gem-gold); }
  .price-pill-active { background: var(--color-gem-gold); border-color: var(--color-gem-gold); color: var(--color-gem-dark); }

  .sidebar-neighborhood-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    max-height: 200px;
    overflow-y: auto;
  }

  .sidebar-neighborhood-item {
