<script>
  // FAQ accordion
  document.querySelectorAll(".faq-trigger").forEach(trigger => {
    trigger.addEventListener("click", () => {
      const item = trigger.closest(".faq-item");
      const isOpen = item?.classList.contains("open");
      document.querySelectorAll(".faq-item").forEach(i => i.classList.remove("open"));
      if (!isOpen) item?.classList.add("open");
    });
  });

  // Star picker
  const starBtns = document.querySelectorAll(".star-pick-btn");
  const ratingInput = document.getElementById("rating-input") as HTMLInputElement;
  let selectedRating = 0;

  starBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      selectedRating = parseInt((btn as HTMLElement).dataset.value ?? "0");
      ratingInput.value = String(selectedRating);
      starBtns.forEach((b, i) => {
        b.textContent = i < selectedRating ? "★" : "☆";
        b.classList.toggle("filled", i < selectedRating);
      });
    });
    btn.addEventListener("mouseenter", () => {
      const hoverVal = parseInt((btn as HTMLElement).dataset.value ?? "0");
      starBtns.forEach((b, i) => { b.textContent = i < hoverVal ? "★" : "☆"; });
    });
    btn.addEventListener("mouseleave", () => {
      starBtns.forEach((b, i) => { b.textContent = i < selectedRating ? "★" : "☆"; });
    });
  });

  // Review form
  document.getElementById("review-form")?.addEventListener("submit", async e => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = new FormData(form);

    if (!data.get("rating")) {
      alert("Please select a star rating.");
      return;
    }

    try {
      const res = await fetch("/api/reviews", {
        method: "POST",
        body: JSON.stringify(Object.fromEntries(data)),
        headers: { "Content-Type": "application/json" },
      });

      if (res.ok) {
        form.reset();
        selectedRating = 0;
        ratingInput.value = "";
        starBtns.forEach(b => { b.textContent = "☆"; b.classList.remove("filled"); });
        alert("Thanks for your review! It will appear after moderation.");
      } else {
        alert("Something went wrong. Please try again.");
      }
    } catch {
      alert("Something went wrong. Please try again.");
    }
  });
</script>