---
// src/pages/listings/[slug].astro
import PublicLayout from "@/layouts/PublicLayout.astro";
import { GET } from "@/pages/api/web/listings";
import { createLocalBusinessSchema, createBreadcrumbSchema, SITE_URL } from "@/lib/schema";

const { slug } = Astro.params;

const apiUrl = new URL(Astro.request.url);
apiUrl.searchParams.set("slug", slug ?? "");

const response = await GET({ request: new Request(apiUrl.toString()) } as any);
const data = await response.json();

if (data.notFound) {
  return Astro.redirect("/explore");
}

const { biz, reviews, upcomingEvents, related } = data;

// Is this listing claimable?
const isUnclaimed = !biz.userId && biz.claimStatus !== "PENDING";
const claimUrl = `/claim?slug=${biz.slug}&name=${encodeURIComponent(biz.name)}`;

const priceMap: Record<string, string> = {
  ONE: "$", TWO: "$$", THREE: "$$$", FOUR: "$$$$",
};

const categoryIcons: Record<string, string> = {
  "Food & Drink": "🍽️",
  "Health & Wellness": "💆",
  "Shopping": "🛍️",
  "Home Services": "🔧",
  "Arts & Entertainment": "🎭",
  "Professional Services": "💼",
  "Education": "📚",
  "Automotive": "🚗",
};

const socialIcons: Record<string, string> = {
  INSTAGRAM: "📸", FACEBOOK: "👥", TIKTOK: "🎵", TWITTER: "🐦",
  YOUTUBE: "▶️", LINKEDIN: "💼", YELP: "⭐", TRIPADVISOR: "✈️", OTHER: "🔗",
};

const days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
const today = new Date().getDay();

function formatTime(time: string | null) {
  if (!time) return "";
  const [h, m] = time.split(":").map(Number);
  const ampm = h >= 12 ? "PM" : "AM";
  const hour = h % 12 || 12;
  return `${hour}:${m.toString().padStart(2, "0")} ${ampm}`;
}

function getTodayHours(hours: any[]) {
  const todayHours = hours?.find((h: any) => h.dayOfWeek === today);
  if (!todayHours) return "Hours not listed";
  if (todayHours.isClosed) return "Closed today";
  return `Open today: ${formatTime(todayHours.openTime)} – ${formatTime(todayHours.closeTime)}`;
}

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5;
  const empty = 5 - full - (half ? 1 : 0);
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}

function formatEventDate(dateStr: string) {
  return new Intl.DateTimeFormat("en-US", {
    weekday: "short", month: "short", day: "numeric",
    hour: "numeric", minute: "2-digit",
  }).format(new Date(dateStr));
}

function formatReviewDate(dateStr: string) {
  return new Intl.DateTimeFormat("en-US", {
    month: "long", day: "numeric", year: "numeric",
  }).format(new Date(dateStr));
}

const primaryLocation = biz.locations?.find((l: any) => l.isPrimary) ?? biz.locations?.[0];
const primaryImage = biz.images?.find((i: any) => i.isPrimary) ?? biz.images?.[0];
const otherImages = biz.images?.filter((i: any) => !i.isPrimary) ?? [];
const todayHoursText = primaryLocation ? getTodayHours(primaryLocation.hours) : "Hours not listed";
const hasBooking = biz.bookingUrl;
const hasWebsite = biz.websiteUrl;
const primaryCtaHref = hasBooking ? biz.bookingUrl : hasWebsite ? biz.websiteUrl : null;
const primaryCtaLabel = hasBooking ? "Book Now →" : "Visit Website →";
const googleMapsUrl = primaryLocation
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${primaryLocation.address}, ${primaryLocation.city}, ${primaryLocation.state}`)}`
  : null;

// ─── Schema ───────────────────────────────────────────────
const schemas = [
  createLocalBusinessSchema({
    name: biz.name,
    slug: biz.slug,
    description: biz.bio,
    image: primaryImage?.url,
    phone: biz.contact?.phone,
    email: biz.contact?.email,
    websiteUrl: biz.websiteUrl,
    address: primaryLocation?.address,
    city: primaryLocation?.city,
    state: primaryLocation?.state,
    zip: primaryLocation?.zip,
    lat: primaryLocation?.lat,
    lng: primaryLocation?.lng,
    pricePoint: biz.pricePoint,
    averageRating: biz.averageRating,
    reviewCount: biz.reviewCount,
    categoryName: biz.category?.name,
    hours: primaryLocation?.hours,
    socials: biz.socials,
  }),
  createBreadcrumbSchema([
    { name: "Home", url: SITE_URL },
    { name: "Explore", url: `${SITE_URL}/explore` },
    { name: biz.category.name, url: `${SITE_URL}/explore/${biz.category.slug}` },
    { name: biz.name, url: `${SITE_URL}/listings/${biz.slug}` },
  ]),
];
---

<PublicLayout
  title={biz.name}
  description={biz.bio ?? `${biz.name} — ${biz.category.name} in Boise, ID`}
  image={primaryImage?.url}
  schemas={schemas}
>
  <!-- HERO -->
  <div class="listing-hero">
    <div class="listing-hero-bg" style={primaryImage ? `background-image: url('${primaryImage.url}')` : ""}></div>
    <div class="listing-hero-overlay"></div>
    <div class="listing-hero-content section-container">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/explore">Explore</a>
        <span>›</span>
        <a href={`/explore/${biz.category.slug}`}>{biz.category.name}</a>
        <span>›</span>
        <span>{biz.name}</span>
      </nav>

      <div class="listing-hero-body">
        <div>
          <div class="listing-hero-badges">
            {biz.isGemOfWeek && <span class="gem-badge">💎 Gem of the Week</span>}
            {biz.isVerified && <span class="verified-badge">✓ Verified</span>}
            {isUnclaimed && <span class="unclaimed-badge">Unclaimed</span>}
          </div>

          <h1 class="listing-hero-title">{biz.name}</h1>

          <div class="listing-hero-meta">
            <span class="biz-card-cat">{biz.category.name}</span>
            {biz.subcategory && <span class="listing-meta-sep">·</span>}
            {biz.subcategory && <span class="listing-hero-subcat">{biz.subcategory.name}</span>}
            {biz.pricePoint && <span class="listing-meta-sep">·</span>}
            {biz.pricePoint && <span class="listing-hero-price">{priceMap[biz.pricePoint]}</span>}
          </div>

          {biz.reviewCount > 0 && (
            <div class="listing-hero-rating">
              <span class="listing-stars">{renderStars(biz.averageRating)}</span>
              <span class="listing-rating-num">{biz.averageRating.toFixed(1)}</span>
              <a href="#reviews" class="listing-rating-count">
                ({biz.reviewCount} {biz.reviewCount === 1 ? "review" : "reviews"})
              </a>
            </div>
          )}
        </div>

        <!-- Desktop CTA buttons — hidden on tablet/mobile -->
        <div class="listing-hero-ctas desktop-ctas">
          {hasBooking && (
            <a href={biz.bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-gold">
              Book Now →
            </a>
          )}
          {hasWebsite && (
            <a href={biz.websiteUrl} target="_blank" rel="noopener noreferrer" class="btn-outline-white">
              Visit Website
            </a>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- QUICK INFO BAR -->
  <div class="info-bar">
    <div class="section-container">
      <div class="info-bar-inner">
        {primaryLocation && (
          <div class="info-bar-item">
            <span class="info-bar-icon">📍</span>
            <span>{primaryLocation.neighborhood ?? primaryLocation.city}, {primaryLocation.state}</span>
          </div>
        )}
        {primaryLocation?.hours && (
          <div class="info-bar-item">
            <span class="info-bar-icon">🕐</span>
            <span>{todayHoursText}</span>
          </div>
        )}
        {biz.contact?.phone && (
          <a href={`tel:${biz.contact.phone}`} class="info-bar-item info-bar-link">
            <span class="info-bar-icon">📞</span>
            <span>{biz.contact.phone}</span>
          </a>
        )}
        {biz.contact?.email && (
          <a href={`mailto:${biz.contact.email}`} class="info-bar-item info-bar-link">
            <span class="info-bar-icon">✉️</span>
            <span>{biz.contact.email}</span>
          </a>
        )}
        {googleMapsUrl && (
          <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="info-bar-item info-bar-link">
            <span class="info-bar-icon">🗺️</span>
            <span>Get Directions</span>
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="listing-layout section-container">

    <!-- LEFT COLUMN -->
    <div class="listing-main">

      {biz.bio && (
        <section class="listing-section">
          <h2 class="listing-section-title">About {biz.name}</h2>
          <p class="listing-bio">{biz.bio}</p>
          {biz.keywords?.length > 0 && (
            <div class="listing-tags">
              {biz.keywords.map((kw: string) => (
                <span class="listing-tag">{kw}</span>
              ))}
            </div>
          )}
        </section>
      )}

      {otherImages.length > 0 && (
        <section class="listing-section">
          <h2 class="listing-section-title">Photos</h2>
          <div class="photo-gallery">
            {otherImages.slice(0, 6).map((img: any) => (
              <div class="photo-item">
                <img src={img.url} alt={img.alt ?? biz.name} loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      )}

      {biz.amenities?.length > 0 && (
        <section class="listing-section">
          <h2 class="listing-section-title">Amenities</h2>
          <div class="amenities-grid">
            {biz.amenities.map((ba: any) => (
              <div class="amenity-item">
                <span class="amenity-check">✓</span>
                <span>{ba.amenity.label}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      {biz.features?.length > 0 && (
        <section class="listing-section">
          <h2 class="listing-section-title">Features</h2>
          <div class="features-list">
            {biz.features.map((bf: any) => (
              <span class="feature-badge">{bf.feature.label}</span>
            ))}
          </div>
        </section>
      )}

      {biz.faqs?.length > 0 && (
        <section class="listing-section">
          <h2 class="listing-section-title">Frequently Asked Questions</h2>
          <div class="faq-list">
            {biz.faqs.map((f: any, i: number) => (
              <div class="faq-item" id={`faq-${i}`}>
                <button class="faq-trigger" aria-expanded="false">
                  {f.question}
                  <span class="faq-icon">+</span>
                </button>
                <div class="faq-body">{f.answer}</div>
              </div>
            ))}
          </div>
        </section>
      )}

      {upcomingEvents?.length > 0 && (
        <section class="listing-section">
          <h2 class="listing-section-title">Upcoming Events</h2>
          <div class="events-list">
            {upcomingEvents.map((evt: any) => (
              <a href={`/events/${evt.id}`} class="event-list-item">
                <div class="event-list-date">{formatEventDate(evt.startDateTime)}</div>
                <div class="event-list-body">
                  <div class="event-list-title">{evt.title}</div>
                  <div class="event-list-cat">{evt.category.replace(/_/g, " ")}</div>
                </div>
                {evt.ticketUrl && <span class="event-list-ticket">Tickets →</span>}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- REVIEWS -->
      <section class="listing-section" id="reviews">
        <div class="reviews-header">
          <h2 class="listing-section-title">
            Reviews
            {reviews.length > 0 && <span class="reviews-count">({reviews.length})</span>}
          </h2>
          {biz.reviewCount > 0 && (
            <div class="reviews-summary">
              <span class="reviews-avg-stars">{renderStars(biz.averageRating)}</span>
              <span class="reviews-avg-num">{biz.averageRating.toFixed(1)}</span>
              <span class="reviews-avg-label">out of 5</span>
            </div>
          )}
        </div>

        {reviews.length > 0 ? (
          <div class="reviews-list">
            {reviews.map((r: any) => (
              <div class="review-item">
                <div class="review-header">
                  <div class="review-author-wrap">
                    <div class="review-avatar">{r.authorName.charAt(0).toUpperCase()}</div>
                    <div>
                      <div class="review-author">{r.authorName}</div>
                      <div class="review-date">{formatReviewDate(r.createdAt)}</div>
                    </div>
                  </div>
                  <div class="review-stars">{renderStars(r.rating)}</div>
                </div>
                {r.body && <p class="review-body">{r.body}</p>}

                <!-- Claim-to-reply prompt on each review -->
                {isUnclaimed && (
                  <div class="review-claim-reply">
                    <span class="review-claim-lock">🔒</span>
                    <span class="review-claim-text">Is this your business?</span>
                    <a href={claimUrl} class="review-claim-link">Claim this listing to respond →</a>
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          <p class="no-reviews">No reviews yet. Be the first to leave one!</p>
        )}

        <!-- Review form -->
        <div class="review-form-wrap">
          <h3 class="review-form-title">Leave a Review</h3>
          <form class="review-form" id="review-form">
            <input type="hidden" name="businessId" value={biz.id} />
            <div class="form-row">
              <div class="form-field">
                <label class="gem-label" for="r-name">Your Name</label>
                <input class="gem-input" id="r-name" name="authorName" type="text" placeholder="Jane Smith" required />
              </div>
              <div class="form-field">
                <label class="gem-label" for="r-email">Email</label>
                <input class="gem-input" id="r-email" name="authorEmail" type="email" placeholder="jane@email.com" required />
              </div>
            </div>
            <div class="form-field">
              <label class="gem-label">Rating</label>
              <div class="star-picker" role="group" aria-label="Rating">
                {[1,2,3,4,5].map(n => (
                  <button type="button" class="star-pick-btn" data-value={n} aria-label={`${n} star${n > 1 ? "s" : ""}`}>☆</button>
                ))}
              </div>
              <input type="hidden" name="rating" id="rating-input" value="" required />
            </div>
            <div class="form-field">
              <label class="gem-label" for="r-body">Your Review</label>
              <textarea class="gem-textarea" id="r-body" name="body" placeholder="Tell others about your experience…"></textarea>
            </div>
            <button type="submit" class="btn-gold">Submit Review →</button>
          </form>
        </div>
      </section>
    </div>

    <!-- RIGHT SIDEBAR -->
    <aside class="listing-sidebar">

      <!-- CTA Card -->
      {(hasBooking || hasWebsite) && (
        <div class="sidebar-card cta-card">
          {hasBooking && (
            <a href={biz.bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-gold w-full text-center">
              Book Now →
            </a>
          )}
          {hasWebsite && (
            <a href={biz.websiteUrl} target="_blank" rel="noopener noreferrer" class="btn-outline-white w-full text-center" style="margin-top: 0.75rem;">
              Visit Website
            </a>
          )}
        </div>
      )}

      <!-- Contact Card -->
      {(biz.contact?.phone || biz.contact?.email || primaryLocation) && (
        <div class="sidebar-card">
          <h3 class="sidebar-card-title">Contact & Location</h3>
          <div class="contact-list">
            {primaryLocation && (
              <div class="contact-item">
                <span class="contact-icon">📍</span>
                <div>
                  <div>{primaryLocation.address}</div>
                  <div>{primaryLocation.city}, {primaryLocation.state} {primaryLocation.zip}</div>
                  {googleMapsUrl && (
                    <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="contact-link">Get Directions →</a>
                  )}
                </div>
              </div>
            )}
            {biz.contact?.phone && (
              <div class="contact-item">
                <span class="contact-icon">📞</span>
                <a href={`tel:${biz.contact.phone}`} class="contact-link">{biz.contact.phone}</a>
              </div>
            )}
            {biz.contact?.email && (
              <div class="contact-item">
                <span class="contact-icon">✉️</span>
                <a href={`mailto:${biz.contact.email}`} class="contact-link">{biz.contact.email}</a>
              </div>
            )}
            {biz.websiteUrl && (
              <div class="contact-item">
                <span class="contact-icon">🌐</span>
                <a href={biz.websiteUrl} target="_blank" rel="noopener noreferrer" class="contact-link">
                  {biz.websiteUrl.replace(/^https?:\/\//, "").replace(/\/$/, "")}
                </a>
              </div>
            )}
          </div>
        </div>
      )}

      <!-- CLAIM CARD — sidebar, only for unclaimed listings -->
      {isUnclaimed && (
        <div class="sidebar-card claim-card">
          <div class="claim-card-eyebrow">🏪 Is this your business?</div>
          <h3 class="claim-card-title">Claim this listing</h3>
          <p class="claim-card-text">
            Take control of your profile, respond to reviews, add photos, and manage your hours — starting at $9/mo.
          </p>
          <a href={claimUrl} class="btn-gold claim-card-btn">
            Claim This Listing →
          </a>
        </div>
      )}

      <!-- Hours Card -->
      {primaryLocation?.hours?.length > 0 && (
        <div class="sidebar-card">
          <h3 class="sidebar-card-title">Hours</h3>
          <div class="hours-list">
            {days.map((day, i) => {
              const h = primaryLocation.hours.find((hr: any) => hr.dayOfWeek === i);
              const isToday = i === today;
              return (
                <div class:list={["hours-row", isToday && "hours-today"]}>
                  <span class="hours-day">{day}</span>
                  <span class="hours-time">
                    {!h || h.isClosed ? "Closed" : `${formatTime(h.openTime)} – ${formatTime(h.closeTime)}`}
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {biz.locations?.length > 1 && (
        <div class="sidebar-card">
          <h3 class="sidebar-card-title">Locations</h3>
          <div class="locations-list">
            {biz.locations.map((loc: any) => (
              <div class="location-item">
                {loc.isPrimary && <span class="location-primary-badge">Primary</span>}
                <div class="location-address">{loc.address}<br />{loc.city}, {loc.state} {loc.zip}</div>
                {loc.neighborhood && <div class="location-neighborhood">{loc.neighborhood}</div>}
                <a
                  href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${loc.address}, ${loc.city}, ${loc.state}`)}`}
                  target="_blank" rel="noopener noreferrer" class="contact-link"
                >Get Directions →</a>
              </div>
            ))}
          </div>
        </div>
      )}

      {biz.socials?.length > 0 && (
        <div class="sidebar-card">
          <h3 class="sidebar-card-title">Follow Along</h3>
          <div class="socials-list">
            {biz.socials.map((s: any) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-item">
                <span>{socialIcons[s.platform] ?? "🔗"}</span>
                <span>{s.platform.charAt(0) + s.platform.slice(1).toLowerCase()}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      {biz.spotlights?.length > 0 && (
        <div class="sidebar-card spotlight-card">
          <div class="spotlight-eyebrow">💎 Gem Spotlight</div>
          <h3 class="spotlight-headline">{biz.spotlights[0].headline}</h3>
          <p class="spotlight-week">{biz.spotlights[0].weekLabel}</p>
          <a href="/gems" class="contact-link">Read the full feature →</a>
        </div>
      )}
    </aside>
  </div>

  <!-- RELATED BUSINESSES -->
  {related?.length > 0 && (
    <section class="related-section">
      <div class="section-container">
        <div class="section-header">
          <span class="section-eyebrow">More in {biz.category.name}</span>
          <h2 class="section-title">You Might Also <em>Like</em></h2>
        </div>
        <div class="related-grid">
          {related.map((r: any) => (
            <a href={`/listings/${r.slug}`} class="biz-card">
              <div class="biz-card-img">
                {r.images[0] ? (
                  <img src={r.images[0].url} alt={r.images[0].alt ?? r.name} loading="lazy" />
                ) : (
                  <span>{categoryIcons[r.category.name] ?? "📍"}</span>
                )}
              </div>
              <div class="biz-card-body">
                <div class="biz-card-meta">
                  <span class="biz-card-cat">{r.category.name}</span>
                  {r.pricePoint && <span class="biz-card-price">{priceMap[r.pricePoint]}</span>}
                </div>
                <div class="biz-card-name">{r.name}</div>
                {r.locations[0]?.neighborhood && (
                  <div class="biz-card-location">{r.locations[0].neighborhood}, Boise</div>
                )}
                {r.reviewCount > 0 && (
                  <div class="biz-card-rating">
                    <span>{renderStars(r.averageRating)}</span>
                    <span>({r.reviewCount})</span>
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- STICKY MOBILE CTA BAR — tablet and below only -->
  {primaryCtaHref && (
    <div class="sticky-cta-bar" id="sticky-cta-bar">
      <a href={primaryCtaHref} target="_blank" rel="noopener noreferrer" class="sticky-cta-primary">
        {primaryCtaLabel}
      </a>
      {isUnclaimed && (
        <a href={claimUrl} class="sticky-cta-claim">
          Own this? Claim it →
        </a>
      )}
    </div>
  )}

  {/* If no booking/website but unclaimed, show claim-only bar */}
  {!primaryCtaHref && isUnclaimed && (
    <div class="sticky-cta-bar sticky-cta-bar-claim-only" id="sticky-cta-bar">
      <a href={claimUrl} class="sticky-cta-primary">
        Is this your business? Claim it →
      </a>
    </div>
  )}
</PublicLayout>

<style>
  /* ── HERO ── */
  .listing-hero { position: relative; min-height: 420px; display: flex; align-items: flex-end; overflow: hidden; padding-top: 4rem; }
  .listing-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; background-color: var(--color-gem-dark-2); }
  .listing-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,13,13,0.2) 0%, rgba(13,13,13,0.85) 100%); }
  .listing-hero-content { position: relative; z-index: 2; padding-bottom: 2.5rem; width: 100%; }

  .hero-breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-bottom: 1rem; flex-wrap: wrap; }
  .hero-breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.15s; }
  .hero-breadcrumb a:hover { color: var(--color-gem-gold); }

  .listing-hero-body { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .listing-hero-badges { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; flex-wrap: wrap; }

  .unclaimed-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 100px;
