---
// src/pages/blog/[slug].astro
import PublicLayout from "@/layouts/PublicLayout.astro";
import { getCollection, render } from "astro:content";
import { createBlogPostSchema, createBreadcrumbSchema, SITE_URL } from "@/lib/schema";

const { slug } = Astro.params;

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const post = allPosts.find((p) => p.id === slug);

if (!post) {
  return Astro.redirect("/blog");
}

const { Content } = await render(post);

const related = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);
}

// ─── Schema ───────────────────────────────────────────────
const schemas = [
  createBlogPostSchema({
    title: post.data.title,
    description: post.data.description,
    slug: post.id,
    image: post.data.coverImage,
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    author: post.data.author,
    category: post.data.category,
  }),
  createBreadcrumbSchema([
    { name: "Home", url: SITE_URL },
    { name: "Blog", url: `${SITE_URL}/blog` },
    { name: post.data.category, url: `${SITE_URL}/blog?category=${encodeURIComponent(post.data.category)}` },
    { name: post.data.title, url: `${SITE_URL}/blog/${post.id}` },
  ]),
];
---

<PublicLayout
  title={`${post.data.title} — Hidden Gems Boise`}
  description={post.data.description}
  image={post.data.coverImage}
  article={{
    publishedTime: post.data.pubDate,
    modifiedTime: post.data.updatedDate,
    authors: [post.data.author],
    tags: [post.data.category],
  }}
  schemas={schemas}
>
  <!-- HERO -->
  <div class="post-hero">
    {
      post.data.coverImage && (
        <>
          <div
            class="post-hero-bg"
            style={`background-image: url('${post.data.coverImage}')`}
          />
          <div class="post-hero-overlay" />
        </>
      )
    }
    <div class="post-hero-content section-container">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/blog">Blog</a>
        <span>›</span>
        <span>{post.data.category}</span>
      </nav>
      <span class="post-category-hero">{post.data.category}</span>
      <h1 class="post-hero-title">{post.data.title}</h1>
      <div class="post-hero-meta">
        <span>{post.data.author}</span>
        <span>·</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        {
          post.data.updatedDate && (
            <>
              <span>·</span>
              <span>Updated {formatDate(post.data.updatedDate)}</span>
            </>
          )
        }
      </div>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="post-layout section-container">
    <article class="post-article">
      <div class="post-body prose">
        <Content />
      </div>

      <!-- AUTHOR BIO -->
      <div class="author-card">
        <div class="author-avatar">R</div>
        <div class="author-info">
          <div class="author-name">{post.data.author}</div>
          <div class="author-bio">
            Founder of Hidden Gems Boise and Velocity Web Studio. Helping
            Treasure Valley businesses grow their digital presence through
            curated storytelling and smart web design.
          </div>
          <a href="/about" class="author-link">About Richard →</a>
        </div>
      </div>

      <!-- CTA -->
      <div class="post-cta">
        <div class="post-cta-inner">
          <div>
            <h3 class="post-cta-title">Know a hidden gem?</h3>
            <p class="post-cta-sub">
              Help us spotlight the best independently owned businesses in the
              Treasure Valley.
            </p>
          </div>
          <a href="/submit" class="btn-gold">List Your Business →</a>
        </div>
      </div>
    </article>

    <!-- SIDEBAR -->
    <aside class="post-sidebar">
      <div class="sidebar-card">
        <h3 class="sidebar-card-title">Browse the Directory</h3>
        <p class="sidebar-text">
          Discover independently owned businesses across Boise and the Treasure
          Valley.
        </p>
        <a href="/explore" class="btn-gold sidebar-btn">Explore Now →</a>
      </div>

      {
        related.length > 0 && (
          <div class="sidebar-card">
            <h3 class="sidebar-card-title">More in {post.data.category}</h3>
            <div class="related-posts">
              {related.map((rp) => (
                <a href={`/blog/${rp.id}`} class="related-post-item">
                  {rp.data.coverImage && (
                    <img
                      src={rp.data.coverImage}
                      alt={rp.data.title}
                      class="related-post-img"
                      loading="lazy"
                    />
                  )}
                  <div>
                    <div class="related-post-title">{rp.data.title}</div>
                    <time
                      class="related-post-date"
                      datetime={rp.data.pubDate.toISOString()}
                    >
                      {formatDate(rp.data.pubDate)}
                    </time>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </aside>
  </div>
</PublicLayout>

<style>
  .post-hero { position: relative; min-height: 380px; display: flex; align-items: flex-end; overflow: hidden; padding-top: 4rem; background: var(--color-gem-dark); }
  .post-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .post-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,13,13,0.2) 0%, rgba(13,13,13,0.88) 100%); }
  .post-hero-content { position: relative; z-index: 2; padding-bottom: 2.5rem; width: 100%; }
  .hero-breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem; }
  .hero-breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
  .hero-breadcrumb a:hover { color: var(--color-gem-gold); }
  .post-category-hero { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gem-gold); display: block; margin-bottom: 0.75rem; }
  .post-hero-title { font-family: var(--font-display); font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 600; color: white; line-height: 1.15; margin-bottom: 1rem; max-width: 760px; }
  .post-hero-meta { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: rgba(255,255,255,0.55); flex-wrap: wrap; }

  .post-layout { display: grid; grid-template-columns: 1fr 280px; gap: 3rem; padding-top: 3rem; padding-bottom: 4rem; align-items: start; }
  @media (max-width: 1024px) { .post-layout { grid-template-columns: 1fr; } .post-sidebar { order: -1; } }

  .post-article { display: flex; flex-direction: column; gap: 2rem; }

  .post-body { font-size: 1.0625rem; line-height: 1.8; color: var(--color-gem-text); }
  .post-body :global(h2) { font-family: var(--font-display); font-size: 1.75rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--color-gem-text); }
  .post-body :global(h3) { font-family: var(--font-display); font-size: 1.375rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .post-body :global(p) { margin-bottom: 1.25rem; }
  .post-body :global(a) { color: var(--color-gem-gold); text-decoration: underline; }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .post-body :global(li) { margin-bottom: 0.375rem; }
  .post-body :global(blockquote) { border-left: 3px solid var(--color-gem-gold); padding-left: 1.25rem; margin: 1.5rem 0; color: var(--color-gem-text-muted); font-style: italic; }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--color-gem-border); margin: 2rem 0; }
  .post-body :global(img) { width: 100%; border-radius: 10px; margin: 1.5rem 0; }
  .post-body :global(code) { background: var(--color-gem-mist); padding: 0.125rem 0.375rem; border-radius: 4px; font-size: 0.9em; }
  .post-body :global(pre) { background: var(--color-gem-dark); color: white; padding: 1.25rem; border-radius: 10px; overflow-x: auto; margin: 1.5rem 0; }

  .author-card { display: flex; gap: 1rem; align-items: flex-start; padding: 1.5rem; background: var(--color-gem-mist); border-radius: 12px; border: 1.5px solid var(--color-gem-border); }
  .author-avatar { width: 3rem; height: 3rem; border-radius: 50%; background: var(--color-gem-gold); color: var(--color-gem-dark); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.25rem; flex-shrink: 0; }
  .author-name { font-weight: 700; font-size: 0.9375rem; margin-bottom: 0.25rem; }
  .author-bio { font-size: 0.875rem; color: var(--color-gem-text-muted); line-height: 1.6; margin-bottom: 0.5rem; }
  .author-link { font-size: 0.8125rem; font-weight: 600; color: var(--color-gem-gold); text-decoration: none; }
  .author-link:hover { text-decoration: underline; }

  .post-cta { background: var(--color-gem-dark); border-radius: 12px; padding: 1.75rem; }
  .post-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .post-cta-title { font-family: var(--font-display); font-size: 1.375rem; font-weight: 600; color: white; margin-bottom: 0.375rem; }
  .post-cta-sub { font-size: 0.875rem; color: rgba(255,255,255,0.55); }

  .post-sidebar { display: flex; flex-direction: column; gap: 1.25rem; position: sticky; top: 100px; }
  .sidebar-card { background: white; border-radius: 12px; border: 1.5px solid var(--color-gem-border); padding: 1.25rem; }
  .sidebar-card-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; margin-bottom: 0.625rem; }
  .sidebar-text { font-size: 0.875rem; color: var(--color-gem-text-muted); line-height: 1.6; margin-bottom: 1rem; }
  .sidebar-btn { display: block; text-align: center; }

  .related-posts { display: flex; flex-direction: column; gap: 1rem; }
  .related-post-item { display: flex; gap: 0.75rem; align-items: center; text-decoration: none; color: inherit; transition: opacity 0.15s; }
  .related-post-item:hover { opacity: 0.75; }
  .related-post-img { width: 56px; height: 56px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }
  .related-post-title { font-size: 0.875rem; font-weight: 600; line-height: 1.35; margin-bottom: 0.2rem; }
  .related-post-date { font-size: 0.75rem; color: var(--color-gem-text-subtle); }
</style>