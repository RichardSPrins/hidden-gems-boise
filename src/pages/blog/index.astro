---
// src/pages/blog/index.astro
import PublicLayout from "@/layouts/PublicLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const featured = sorted.find((p) => p.data.featured);
const rest = sorted.filter((p) => !p.data.featured || p.id !== featured?.id);

const categories = [
  "Local Business",
  "Events",
  "Neighborhood Guides",
  "Business Tips",
  "Hidden Gems Features",
];

const selectedCategory = Astro.url.searchParams.get("category") ?? "";
const filtered = selectedCategory
  ? rest.filter((p) => p.data.category === selectedCategory)
  : rest;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);
}
---

<PublicLayout
  title="Blog — Hidden Gems Boise"
  description="Stories, guides, and insights about independently owned businesses across the Treasure Valley."
>
  <!-- HERO -->
  <div class="blog-hero">
    <div class="blog-hero-bg"></div>
    <div class="blog-hero-overlay"></div>
    <div class="blog-hero-content section-container">
      <p class="section-eyebrow" style="color: var(--color-gem-gold-light)">
        Stories & Guides
      </p>
      <h1 class="blog-hero-title">The Hidden Gems <em>Blog</em></h1>
      <p class="blog-hero-sub">
        Local business stories, neighborhood guides, and insider tips for the
        Treasure Valley.
      </p>
    </div>
  </div>

  <div class="blog-layout section-container">
    <!-- FEATURED POST -->
    {
      featured && !selectedCategory && (
        <a href={`/blog/${featured.id}`} class="featured-post">
          <div class="featured-post-img">
            {featured.data.coverImage ? (
              <img
                src={featured.data.coverImage}
                alt={featured.data.coverImageAlt ?? featured.data.title}
              />
            ) : (
              <div class="featured-post-img-placeholder">📰</div>
            )}
            <span class="featured-badge">Featured</span>
          </div>
          <div class="featured-post-body">
            <span class="post-category">{featured.data.category}</span>
            <h2 class="featured-post-title">{featured.data.title}</h2>
            <p class="featured-post-desc">{featured.data.description}</p>
            <div class="post-meta">
              <span>{featured.data.author}</span>
              <span>·</span>
              <time datetime={featured.data.pubDate.toISOString()}>
                {formatDate(featured.data.pubDate)}
              </time>
            </div>
          </div>
        </a>
      )
    }

    <!-- CATEGORY FILTER -->
    <div class="blog-filters">
      <a
        href="/blog"
        class:list={[
          "blog-filter-pill",
          !selectedCategory && "blog-filter-active",
        ]}
      >
        All Posts
      </a>
      {
        categories.map((cat) => (
          <a
            href={`/blog?category=${encodeURIComponent(cat)}`}
            class:list={[
              "blog-filter-pill",
              selectedCategory === cat && "blog-filter-active",
            ]}
          >
            {cat}
          </a>
        ))
      }
    </div>

    <!-- POST GRID -->
    {
      filtered.length > 0 ? (
        <div class="post-grid">
          {filtered.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card">
              <div class="post-card-img">
                {post.data.coverImage ? (
                  <img
                    src={post.data.coverImage}
                    alt={post.data.coverImageAlt ?? post.data.title}
                    loading="lazy"
                  />
                ) : (
                  <div class="post-card-img-placeholder">📰</div>
                )}
              </div>
              <div class="post-card-body">
                <span class="post-category">{post.data.category}</span>
                <h2 class="post-card-title">{post.data.title}</h2>
                <p class="post-card-desc">{post.data.description}</p>
                <div class="post-meta">
                  <span>{post.data.author}</span>
                  <span>·</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="no-posts">
          <p class="no-posts-icon">📝</p>
          <h3 class="no-posts-title">No posts yet in this category</h3>
          <p class="no-posts-sub">
            Check back soon — more content is on the way.
          </p>
          <a href="/blog" class="btn-gold">
            View All Posts
          </a>
        </div>
      )
    }
  </div>
</PublicLayout>

<style>
  .blog-hero {
    position: relative;
    height: 280px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-top: 4rem;
  }
  .blog-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("https://images.unsplash.com/photo-1455390582262-044cdead277a?w=1600&auto=format&fit=crop&q=80");
    background-size: cover;
    background-position: center 40%;
  }
  .blog-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 13, 0.3) 0%,
      rgba(13, 13, 13, 0.8) 100%
    );
  }
  .blog-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 2.5rem;
    width: 100%;
  }
  .blog-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 600;
    color: white;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .blog-hero-title em {
    font-style: italic;
    color: var(--color-gem-gold-light);
  }
  .blog-hero-sub {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.9375rem;
  }

  .blog-layout {
    padding-top: 2.5rem;
    padding-bottom: 4rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* FEATURED */
  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1.5px solid var(--color-gem-border);
    text-decoration: none;
    color: inherit;
    background: white;
    transition:
      box-shadow 0.2s,
      transform 0.2s;
  }

  .featured-post:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .featured-post {
      grid-template-columns: 1fr;
    }
  }

  .featured-post-img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-gem-mist-2);
  }
  .featured-post-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .featured-post-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
  }

  .featured-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--color-gem-gold);
    color: var(--color-gem-dark);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  .featured-post-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }
  .featured-post-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 600;
    line-height: 1.2;
    margin: 0;
  }
  .featured-post-desc {
    font-size: 0.9375rem;
    color: var(--color-gem-text-muted);
    line-height: 1.65;
  }

  /* CATEGORY FILTER */
  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .blog-filter-pill {
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid var(--color-gem-border);
    color: var(--color-gem-text-muted);
    background: white;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .blog-filter-pill:hover {
    border-color: var(--color-gem-gold);
    color: var(--color-gem-gold);
  }
  .blog-filter-active {
    background: var(--color-gem-gold);
    border-color: var(--color-gem-gold);
    color: var(--color-gem-dark);
    font-weight: 600;
  }

  /* POST GRID */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    background: white;
    border-radius: 12px;
    border: 1.5px solid var(--color-gem-border);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    border-color: var(--color-gem-gold);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .post-card-img {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-gem-mist-2);
  }
  .post-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .post-card:hover .post-card-img img {
    transform: scale(1.03);
  }
  .post-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
  }

  .post-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .post-card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }
  .post-card-desc {
    font-size: 0.875rem;
    color: var(--color-gem-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* SHARED */
  .post-category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gem-gold);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-gem-text-subtle);
    margin-top: auto;
    padding-top: 0.5rem;
  }

  /* NO POSTS */
  .no-posts {
    text-align: center;
    padding: 4rem 2rem;
    background: white;
    border-radius: 12px;
    border: 1.5px solid var(--color-gem-border);
  }
  .no-posts-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .no-posts-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .no-posts-sub {
    color: var(--color-gem-text-muted);
    margin-bottom: 1.5rem;
  }
</style>
