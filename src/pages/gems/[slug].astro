---
// src/pages/gems/[id].astro
import PublicLayout from "@/layouts/PublicLayout.astro";
import { db } from "@/lib/db";
import { gemSpotlight, image, location } from "@/lib/db/schema";
import { eq, desc, isNotNull, ne } from "drizzle-orm";

const { id } = Astro.params;

const spotlight = await db.query.gemSpotlight.findFirst({
  where: eq(gemSpotlight.id, id ?? ""),
  with: {
    business: {
      with: {
        category: true,
        subcategory: true,
        images: { orderBy: [desc(image.isPrimary)] },
        locations: { where: eq(location.isPrimary, true), limit: 1 },
        contact: true,
        socials: true,
      },
    },
  },
});

if (!spotlight || !spotlight.publishedAt) {
  return Astro.redirect("/gems");
}

// Other gems for sidebar
const otherGems = await db.query.gemSpotlight.findMany({
  where: isNotNull(gemSpotlight.publishedAt),
  orderBy: desc(gemSpotlight.publishedAt),
  limit: 4,
  with: {
    business: {
      with: {
        images: { where: eq(image.isPrimary, true), limit: 1 },
      },
    },
  },
});

const relatedGems = otherGems.filter((g) => g.id !== spotlight.id).slice(0, 3);

const primaryImage =
  spotlight.business.images.find((i) => i.isPrimary) ??
  spotlight.business.images[0];
const otherImages = spotlight.business.images
  .filter((i) => !i.isPrimary)
  .slice(0, 4);
const primaryLocation = spotlight.business.locations[0];

function formatDate(date: Date | string) {
  return new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(new Date(date));
}

const googleMapsUrl = primaryLocation
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${primaryLocation.address}, ${primaryLocation.city}`)}`
  : null;
---

<PublicLayout
  title={`${spotlight.headline} — Hidden Gems Boise`}
  description={spotlight.writeup.slice(0, 160)}
  image={primaryImage?.url}
>
  <!-- HERO -->
  <div class="gem-hero">
    <div
      class="gem-hero-bg"
      style={primaryImage ? `background-image: url('${primaryImage.url}')` : ""}
    >
    </div>
    <div class="gem-hero-overlay"></div>
    <div class="gem-hero-content section-container">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/gems">Gem of the Week</a>
        <span>›</span>
        <span>{spotlight.weekLabel}</span>
      </nav>
      <div class="gem-hero-badge">
        <span>💎 {spotlight.weekLabel}</span>
      </div>
      <h1 class="gem-hero-title">{spotlight.headline}</h1>
      <div class="gem-hero-biz">
        <span class="gem-hero-biz-name">{spotlight.business.name}</span>
        {
          spotlight.business.category && (
            <span class="gem-hero-biz-cat">
              · {spotlight.business.category.name}
            </span>
          )
        }
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="gem-layout section-container">
    <!-- LEFT -->
    <div class="gem-main">
      <!-- Writeup -->
      <div class="gem-section">
        <p class="gem-writeup">{spotlight.writeup}</p>
      </div>

      <!-- Photos -->
      {
        otherImages.length > 0 && (
          <div class="gem-section">
            <h2 class="gem-section-title">Inside {spotlight.business.name}</h2>
            <div class="gem-gallery">
              {otherImages.map((img) => (
                <div class="gem-gallery-item">
                  <img
                    src={img.url}
                    alt={img.alt ?? spotlight.business.name}
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </div>
        )
      }

      <!-- Visit CTA -->
      <div class="gem-visit-cta">
        <div class="gem-visit-cta-inner">
          <div>
            <h3 class="gem-visit-title">Visit {spotlight.business.name}</h3>
            {
              primaryLocation && (
                <p class="gem-visit-addr">
                  {primaryLocation.address}, {primaryLocation.city}
                  {primaryLocation.neighborhood &&
                    ` · ${primaryLocation.neighborhood}`}
                </p>
              )
            }
          </div>
          <div class="gem-visit-actions">
            <a href={`/listings/${spotlight.business.slug}`} class="btn-gold">
              View Full Listing →
            </a>
            {
              googleMapsUrl && (
                <a
                  href={googleMapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-outline-dark"
                >
                  Get Directions
                </a>
              )
            }
          </div>
        </div>
      </div>

      <!-- Share / Nominate -->
      <div class="gem-section gem-nominate">
        <h2 class="gem-section-title">Know a Hidden Gem?</h2>
        <p class="gem-nominate-text">
          Every week we spotlight one standout independently owned business in
          the Treasure Valley. If you know a business that deserves the
          spotlight, submit them — we'd love to feature them.
        </p>
        <a href="/submit" class="btn-gold">Submit a Business →</a>
      </div>
    </div>

    <!-- SIDEBAR -->
    <aside class="gem-sidebar">
      <!-- Business quick info -->
      <div class="sidebar-card">
        <h3 class="sidebar-card-title">About {spotlight.business.name}</h3>
        {
          spotlight.business.bio && (
            <p class="sidebar-text">
              {spotlight.business.bio.slice(0, 180)}
              {spotlight.business.bio.length > 180 ? "…" : ""}
            </p>
          )
        }
        {
          spotlight.business.contact?.phone && (
            <div class="sidebar-contact-item">
              <span>📞</span>
              <a
                href={`tel:${spotlight.business.contact.phone}`}
                class="sidebar-contact-link"
              >
                {spotlight.business.contact.phone}
              </a>
            </div>
          )
        }
        {
          spotlight.business.websiteUrl && (
            <div class="sidebar-contact-item">
              <span>🌐</span>
              <a
                href={spotlight.business.websiteUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="sidebar-contact-link"
              >
                {spotlight.business.websiteUrl
                  .replace(/^https?:\/\//, "")
                  .replace(/\/$/, "")}
              </a>
            </div>
          )
        }
        {
          primaryLocation && (
            <div class="sidebar-contact-item">
              <span>📍</span>
              <span class="sidebar-text">
                {primaryLocation.address}, {primaryLocation.city}
              </span>
            </div>
          )
        }
        <a
          href={`/listings/${spotlight.business.slug}`}
          class="btn-gold sidebar-btn"
          style="margin-top: 1rem;"
        >
          View Full Listing →
        </a>
      </div>

      <!-- Other gems -->
      {
        relatedGems.length > 0 && (
          <div class="sidebar-card">
            <h3 class="sidebar-card-title">More Gem Spotlights</h3>
            <div class="sidebar-gems-list">
              {relatedGems.map((gem) => (
                <a href={`/gems/${gem.id}`} class="sidebar-gem-item">
                  {gem.business.images[0] && (
                    <img
                      src={gem.business.images[0].url}
                      alt={gem.business.name}
                      class="sidebar-gem-img"
                      loading="lazy"
                    />
                  )}
                  <div>
                    <div class="sidebar-gem-week">{gem.weekLabel}</div>
                    <div class="sidebar-gem-headline">{gem.headline}</div>
                  </div>
                </a>
              ))}
            </div>
            <a href="/gems" class="sidebar-view-all">
              View all gems →
            </a>
          </div>
        )
      }
    </aside>
  </div>
</PublicLayout>

<style>
  .gem-hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-top: 4rem;
    background: var(--color-gem-dark);
  }
  .gem-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .gem-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 13, 0.2) 0%,
      rgba(13, 13, 13, 0.85) 100%
    );
  }
  .gem-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 2.5rem;
    width: 100%;
  }
  .hero-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }
  .hero-breadcrumb a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
  }
  .hero-breadcrumb a:hover {
    color: var(--color-gem-gold);
  }

  .gem-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--color-gem-gold);
    color: var(--color-gem-dark);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 0.875rem;
  }

  .gem-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    color: white;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .gem-hero-biz {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .gem-hero-biz-name {
    font-size: 1rem;
    font-weight: 600;
    color: white;
  }
  .gem-hero-biz-cat {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* LAYOUT */
  .gem-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    padding-top: 2.5rem;
    padding-bottom: 4rem;
    align-items: start;
  }
  @media (max-width: 1024px) {
    .gem-layout {
      grid-template-columns: 1fr;
    }
    .gem-sidebar {
      order: -1;
    }
  }

  .gem-main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .gem-section {
    background: white;
    border-radius: 12px;
    border: 1.5px solid var(--color-gem-border);
    padding: 1.75rem;
  }

  .gem-section-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .gem-writeup {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-gem-text);
  }

  .gem-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 640px) {
    .gem-gallery {
      grid-template-columns: 1fr;
    }
  }

  .gem-gallery-item {
    aspect-ratio: 4/3;
    border-radius: 8px;
    overflow: hidden;
  }
  .gem-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gem-visit-cta {
    background: var(--color-gem-dark);
    border-radius: 12px;
    padding: 1.75rem;
  }
  .gem-visit-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .gem-visit-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.375rem;
  }
  .gem-visit-addr {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
  }
  .gem-visit-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .gem-nominate {
    background: var(--color-gem-mist);
  }
  .gem-nominate-text {
    font-size: 0.9375rem;
    color: var(--color-gem-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  /* SIDEBAR */
  .gem-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 100px;
  }
  .sidebar-card {
    background: white;
    border-radius: 12px;
    border: 1.5px solid var(--color-gem-border);
    padding: 1.25rem;
  }
  .sidebar-card-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .sidebar-text {
    font-size: 0.875rem;
    color: var(--color-gem-text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .sidebar-contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-gem-text-muted);
    margin-bottom: 0.5rem;
  }
  .sidebar-contact-link {
    color: var(--color-gem-gold);
    text-decoration: none;
  }
  .sidebar-contact-link:hover {
    text-decoration: underline;
  }

  .sidebar-btn {
    display: block;
    text-align: center;
  }

  .sidebar-gems-list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin-bottom: 0.875rem;
  }

  .sidebar-gem-item {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .sidebar-gem-item:hover {
    opacity: 0.7;
  }

  .sidebar-gem-img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .sidebar-gem-week {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gem-gold);
    margin-bottom: 0.2rem;
  }
  .sidebar-gem-headline {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .sidebar-view-all {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gem-gold);
    text-decoration: none;
  }
  .sidebar-view-all:hover {
    text-decoration: underline;
  }
</style>
