---
// src/pages/events/[category].astro
import PublicLayout from "@/layouts/PublicLayout.astro";
import { GET } from "@/pages/api/web/events/category";

// ─── Event category config ────────────────────────────────
const eventCategoryConfig: Record<
  string,
  {
    label: string;
    icon: string;
    description: string;
    hero: string;
    enumValue: string;
  }
> = {
  "grand-opening": {
    label: "Grand Openings",
    icon: "🎊",
    description:
      "Celebrate new businesses joining the Treasure Valley community.",
    hero: "https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?w=1600&auto=format&fit=crop&q=80",
    enumValue: "GRAND_OPENING",
  },
  "sale-and-promotion": {
    label: "Sales & Promotions",
    icon: "🏷️",
    description:
      "Deals, discounts, and special offers from local Boise businesses.",
    hero: "https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=1600&auto=format&fit=crop&q=80",
    enumValue: "SALE_AND_PROMOTION",
  },
  "workshop-and-class": {
    label: "Workshops & Classes",
    icon: "📝",
    description:
      "Learn something new from local experts across the Treasure Valley.",
    hero: "https://images.unsplash.com/photo-1552664730-d307ca884978?w=1600&auto=format&fit=crop&q=80",
    enumValue: "WORKSHOP_AND_CLASS",
  },
  "live-music-and-entertainment": {
    label: "Live Music & Entertainment",
    icon: "🎵",
    description: "Concerts, performances, and live entertainment across Boise.",
    hero: "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=1600&auto=format&fit=crop&q=80",
    enumValue: "LIVE_MUSIC_AND_ENTERTAINMENT",
  },
  "community-and-networking": {
    label: "Community & Networking",
    icon: "🤝",
    description: "Connect with your neighbors and local business community.",
    hero: "https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1600&auto=format&fit=crop&q=80",
    enumValue: "COMMUNITY_AND_NETWORKING",
  },
  "food-and-drink-special": {
    label: "Food & Drink Specials",
    icon: "🍽️",
    description:
      "Tastings, pop-ups, and culinary events from Boise's best spots.",
    hero: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1600&auto=format&fit=crop&q=80",
    enumValue: "FOOD_AND_DRINK_SPECIAL",
  },
  "seasonal-and-holiday": {
    label: "Seasonal & Holiday",
    icon: "🌟",
    description:
      "Celebrate the seasons with local events and holiday festivities.",
    hero: "https://images.unsplash.com/photo-1543083477-4f785aeafaa9?w=1600&auto=format&fit=crop&q=80",
    enumValue: "SEASONAL_AND_HOLIDAY",
  },
  "charity-and-fundraiser": {
    label: "Charity & Fundraisers",
    icon: "❤️",
    description: "Support local causes and give back to the Treasure Valley.",
    hero: "https://images.unsplash.com/photo-1593113598332-cd288d649433?w=1600&auto=format&fit=crop&q=80",
    enumValue: "CHARITY_AND_FUNDRAISER",
  },
  other: {
    label: "Other Events",
    icon: "📅",
    description: "Discover more happenings across the Treasure Valley.",
    hero: "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=1600&auto=format&fit=crop&q=80",
    enumValue: "OTHER",
  },
};

const { slug } = Astro.params;
const categoryConfig = eventCategoryConfig[slug ?? ""];

if (!categoryConfig) {
  return Astro.redirect("/events");
}

// ─── URL Params ───────────────────────────────────────────
const url = new URL(Astro.request.url);
const q = url.searchParams.get("q") ?? "";
const dateRange = url.searchParams.get("date") ?? "upcoming";
const neighborhood = url.searchParams.get("neighborhood") ?? "";
const recurring = url.searchParams.get("recurring") ?? "";
const sort = url.searchParams.get("sort") ?? "date";
const page = Math.max(1, parseInt(url.searchParams.get("page") ?? "1"));

// ─── API Call ─────────────────────────────────────────────
const apiUrl = new URL(Astro.request.url);
apiUrl.searchParams.set("categoryValue", categoryConfig.enumValue);

const response = await GET({ request: new Request(apiUrl.toString()) } as any);
const data = await response.json();

if (data.notFound) {
  return Astro.redirect("/events");
}

const { results, neighborhoods, count, totalPages } = data;

// ─── All categories for carousel ──────────────────────────
const allCategories = Object.entries(eventCategoryConfig).map(
  ([slug, cfg]) => ({ slug, ...cfg })
);

// ─── Helpers ──────────────────────────────────────────────
function formatEventDate(dateStr: string) {
  const date = new Date(dateStr);
  return {
    month: new Intl.DateTimeFormat("en-US", { month: "short" }).format(date),
    day: new Intl.DateTimeFormat("en-US", { day: "numeric" }).format(date),
    weekday: new Intl.DateTimeFormat("en-US", { weekday: "short" }).format(
      date
    ),
    time: new Intl.DateTimeFormat("en-US", {
      hour: "numeric",
      minute: "2-digit",
    }).format(date),
  };
}

function buildUrl(overrides: Record<string, string | null>) {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (dateRange && dateRange !== "upcoming") params.set("date", dateRange);
  if (neighborhood) params.set("neighborhood", neighborhood);
  if (recurring) params.set("recurring", recurring);
  params.set("sort", sort);
  params.set("page", "1");
  Object.entries(overrides).forEach(([k, v]) => {
    params.delete(k);
    if (v !== null) params.set(k, v);
  });
  const base = `/events/category/${slug}`;
  const qs = params.toString();
  return qs ? `${base}?${qs}` : base;
}

const hasFilters =
  q || (dateRange && dateRange !== "upcoming") || neighborhood || recurring;
---

<PublicLayout
  title={`${categoryConfig.label} in Boise`}
  description={categoryConfig.description}
>
  <!-- SLIM HERO -->
  <div class="events-hero">
    <div
      class="events-hero-bg"
      style={`background-image: url('${categoryConfig.hero}')`}
    >
    </div>
    <div class="events-hero-overlay"></div>
    <div class="events-hero-content section-container">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/events">Events</a>
        <span>›</span>
        <span>{categoryConfig.label}</span>
      </nav>
      <h1 class="events-hero-title">
        {categoryConfig.icon}
        <em>{categoryConfig.label}</em>
      </h1>
      <p class="events-hero-sub">
        {categoryConfig.description} · {Number(count).toLocaleString()} upcoming {
          Number(count) === 1 ? "event" : "events"
        }
      </p>
    </div>
  </div>

  <!-- CATEGORY CAROUSEL -->
  <div class="cat-carousel-bar">
    <div class="cat-carousel-track">
      <a href="/events" class="cat-pill">All Events</a>
      {
        allCategories.map((cat) => (
          <a
            href={`/events/category/${cat.slug}`}
            class:list={["cat-pill", cat.slug === slug && "cat-pill-active"]}
          >
            <span>{cat.icon}</span>
            {cat.label}
          </a>
        ))
      }
    </div>
  </div>

  <!-- MAIN LAYOUT -->
  <div class="explore-layout section-container">
    <!-- SIDEBAR -->
    <aside class="explore-sidebar">
      <div class="sidebar-inner">
        <form
          method="get"
          action={`/events/category/${slug}`}
          class="sidebar-section"
        >
          <label class="sidebar-label">Search</label>
          <div class="sidebar-search-row">
            <input
              type="text"
              name="q"
              value={q}
              placeholder="Search events…"
              class="gem-input sidebar-search-input"
            />
            <input type="hidden" name="sort" value={sort} />
            <button type="submit" class="sidebar-search-btn">Go</button>
          </div>
        </form>

        <div class="sidebar-divider"></div>

        <!-- Browse all categories -->
        <div class="sidebar-section">
          <p class="sidebar-label">Browse Categories</p>
          <ul class="sidebar-cat-list">
            <li>
              <a href="/events" class="sidebar-cat-item">All Events</a>
            </li>
            {
              allCategories.map((cat) => (
                <li>
                  <a
                    href={`/events/category/${cat.slug}`}
                    class:list={[
                      "sidebar-cat-item",
                      cat.slug === slug && "sidebar-cat-active",
                    ]}
                  >
                    <span class="sidebar-cat-icon">{cat.icon}</span>
                    {cat.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="sidebar-divider"></div>

        <!-- When -->
        <div class="sidebar-section">
          <p class="sidebar-label">When</p>
          <ul class="sidebar-cat-list">
            {
              [
                { value: "upcoming", label: "All Upcoming" },
                { value: "week", label: "This Week" },
                { value: "month", label: "This Month" },
              ].map((opt) => (
                <li>
                  <a
                    href={buildUrl({
                      date: opt.value === "upcoming" ? null : opt.value,
                    })}
                    class:list={[
                      "sidebar-cat-item",
                      (dateRange === opt.value ||
                        (!dateRange && opt.value === "upcoming")) &&
                        "sidebar-cat-active",
                    ]}
                  >
                    {opt.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="sidebar-divider"></div>

        <!-- Type -->
        <div class="sidebar-section">
          <p class="sidebar-label">Type</p>
          <ul class="sidebar-cat-list">
            <li>
              <a
                href={buildUrl({ recurring: null })}
                class:list={[
                  "sidebar-cat-item",
                  !recurring && "sidebar-cat-active",
                ]}
              >
                All Types
              </a>
            </li>
            <li>
              <a
                href={buildUrl({ recurring: "false" })}
                class:list={[
                  "sidebar-cat-item",
                  recurring === "false" && "sidebar-cat-active",
                ]}
              >
                One-Time Events
              </a>
            </li>
            <li>
              <a
                href={buildUrl({ recurring: "true" })}
                class:list={[
                  "sidebar-cat-item",
                  recurring === "true" && "sidebar-cat-active",
                ]}
              >
                Recurring Events
              </a>
            </li>
          </ul>
        </div>

        {
          neighborhoods.length > 0 && (
            <>
              <div class="sidebar-divider" />
              <div class="sidebar-section">
                <p class="sidebar-label">Neighborhood</p>
                <ul class="sidebar-neighborhood-list">
                  <li>
                    <a
                      href={buildUrl({ neighborhood: null })}
                      class:list={[
                        "sidebar-neighborhood-item",
                        !neighborhood && "sidebar-neighborhood-active",
                      ]}
                    >
                      All Neighborhoods
                    </a>
                  </li>
                  {neighborhoods.map((n: string) => (
                    <li>
                      <a
                        href={buildUrl({ neighborhood: n })}
                        class:list={[
                          "sidebar-neighborhood-item",
                          neighborhood === n && "sidebar-neighborhood-active",
                        ]}
                      >
                        {n}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </>
          )
        }

        {
          hasFilters && (
            <>
              <div class="sidebar-divider" />
              <div class="sidebar-section">
                <a href={`/events/category/${slug}`} class="sidebar-clear">
                  ✕ Clear filters
                </a>
              </div>
            </>
          )
        }
      </div>
    </aside>

    <!-- RESULTS -->
    <div class="explore-results">
      <div class="results-header">
        <p class="results-count">
          {Number(count).toLocaleString()}
          {Number(count) === 1 ? "event" : "events"}
          {
            q && (
              <span>
                {" "}
                for "<strong>{q}</strong>"
              </span>
            )
          }
        </p>
        <div class="results-controls">
          <button
            class="mobile-filter-btn"
            id="mobile-filter-btn"
            aria-label="Open filters"
          >
            ⚙ Filters {hasFilters && <span class="filter-dot" />}
          </button>
          <form method="get" action={`/events/category/${slug}`}>
            <input type="hidden" name="q" value={q} />
            <input type="hidden" name="date" value={dateRange} />
            <input type="hidden" name="neighborhood" value={neighborhood} />
            <input type="hidden" name="recurring" value={recurring} />
            <select
              name="sort"
              class="sort-select"
              onchange="this.form.submit()"
            >
              <option value="date" selected={sort === "date"}
                >Soonest First</option
              >
              <option value="latest" selected={sort === "latest"}
                >Latest First</option
              >
            </select>
          </form>
        </div>
      </div>

      {
        hasFilters && (
          <div class="filter-chips">
            {q && (
              <a href={buildUrl({ q: null })} class="filter-chip">
                "{q}" ✕
              </a>
            )}
            {dateRange && dateRange !== "upcoming" && (
              <a href={buildUrl({ date: null })} class="filter-chip">
                {dateRange === "week" ? "This Week" : "This Month"} ✕
              </a>
            )}
            {neighborhood && (
              <a href={buildUrl({ neighborhood: null })} class="filter-chip">
                {neighborhood} ✕
              </a>
            )}
            {recurring && (
              <a href={buildUrl({ recurring: null })} class="filter-chip">
                {recurring === "true" ? "Recurring" : "One-Time"} ✕
              </a>
            )}
          </div>
        )
      }

      {
        results.length > 0 ? (
          <ul class="event-list">
            {results.map((evt: any) => {
              const d = formatEventDate(evt.startDateTime);
              return (
                <li class="event-card-item">
                  <div class="event-date-badge">
                    <span class="event-date-month">{d.month}</span>
                    <span class="event-date-day">{d.day}</span>
                    <span class="event-date-weekday">{d.weekday}</span>
                  </div>
                  <div class="event-card-content">
                    <div class="event-card-top">
                      <span class="event-cat-pill">
                        {categoryConfig.icon} {categoryConfig.label}
                      </span>
                      {evt.isRecurring && (
                        <span class="event-recurring-pill">↻ Recurring</span>
                      )}
                    </div>
                    <h2 class="event-card-title">{evt.title}</h2>
                    <div class="event-card-meta">
                      <span>🕐 {d.time}</span>
                      {evt.location?.neighborhood && (
                        <span>📍 {evt.location.neighborhood}</span>
                      )}
                      <a
                        href={`/listings/${evt.business.slug}`}
                        class="event-card-biz-link"
                      >
                        by {evt.business.name}
                      </a>
                    </div>
                    {evt.description && (
                      <p class="event-card-desc">
                        {evt.description.length > 140
                          ? evt.description.slice(0, 137) + "…"
                          : evt.description}
                      </p>
                    )}
                  </div>
                  <div class="event-card-actions">
                    {evt.ticketUrl && (
                      <a
                        href={evt.ticketUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="event-ticket-link"
                      >
                        Tickets →
                      </a>
                    )}
                    <a href={`/events/${evt.id}`} class="event-view-link">
                      View →
                    </a>
                  </div>
                </li>
              );
            })}
          </ul>
        ) : (
          <div class="no-results">
            <p class="no-results-icon">{categoryConfig.icon}</p>
            <h3 class="no-results-title">No {categoryConfig.label} found</h3>
            <p class="no-results-sub">
              Try adjusting your filters or check back soon.
            </p>
            <a href={`/events/category/${slug}`} class="btn-gold">
              Clear Filters
            </a>
          </div>
        )
      }

      {
        totalPages > 1 && (
          <div class="explore-pagination">
            {page > 1 && (
              <a href={buildUrl({ page: String(page - 1) })} class="page-btn">
                ← Previous
              </a>
            )}
            <div class="page-numbers">
              {Array.from(
                { length: totalPages },
                (_: any, i: number) => i + 1
              ).map((p: number) => (
                <a
                  href={buildUrl({ page: String(p) })}
                  class:list={["page-num", p === page && "page-num-active"]}
                >
                  {p}
                </a>
              ))}
            </div>
            {page < totalPages && (
              <a href={buildUrl({ page: String(page + 1) })} class="page-btn">
                Next →
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer-overlay hidden" id="drawer-overlay"></div>
  <div class="mobile-drawer hidden" id="mobile-drawer" aria-hidden="true">
    <div class="mobile-drawer-header">
      <h2 class="mobile-drawer-title">Filters</h2>
      <button class="mobile-drawer-close" id="drawer-close" aria-label="Close"
        >✕</button
      >
    </div>
    <div class="mobile-drawer-body">
      <form
        method="get"
        action={`/events/category/${slug}`}
        class="sidebar-section"
      >
        <label class="sidebar-label">Search</label>
        <div class="sidebar-search-row">
          <input
            type="text"
            name="q"
            value={q}
            placeholder="Search events…"
            class="gem-input"
          />
          <button type="submit" class="sidebar-search-btn">Go</button>
        </div>
      </form>
      <div class="sidebar-divider"></div>
      <div class="sidebar-section">
        <p class="sidebar-label">When</p>
        <ul class="sidebar-cat-list">
          {
            [
              { value: "upcoming", label: "All Upcoming" },
              { value: "week", label: "This Week" },
              { value: "month", label: "This Month" },
            ].map((opt) => (
              <li>
                <a
                  href={buildUrl({
                    date: opt.value === "upcoming" ? null : opt.value,
                  })}
                  class:list={[
                    "sidebar-cat-item",
                    (dateRange === opt.value ||
                      (!dateRange && opt.value === "upcoming")) &&
                      "sidebar-cat-active",
                  ]}
                >
                  {opt.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="sidebar-divider"></div>
      <div class="sidebar-section">
        <p class="sidebar-label">Type</p>
        <ul class="sidebar-cat-list">
          <li>
            <a
              href={buildUrl({ recurring: null })}
              class:list={[
                "sidebar-cat-item",
                !recurring && "sidebar-cat-active",
              ]}>All Types</a
            >
          </li>
          <li>
            <a
              href={buildUrl({ recurring: "false" })}
              class:list={[
                "sidebar-cat-item",
                recurring === "false" && "sidebar-cat-active",
              ]}>One-Time</a
            >
          </li>
          <li>
            <a
              href={buildUrl({ recurring: "true" })}
              class:list={[
                "sidebar-cat-item",
                recurring === "true" && "sidebar-cat-active",
              ]}>Recurring</a
            >
          </li>
        </ul>
      </div>
      {
        hasFilters && (
          <>
            <div class="sidebar-divider" />
            <div class="sidebar-section">
              <a href={`/events/category/${slug}`} class="sidebar-clear">
                ✕ Clear filters
              </a>
            </div>
          </>
        )
      }
    </div>
  </div>
</PublicLayout>

<style>
  .events-hero {
    position: relative;
    height: 300px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    padding-top: 4rem;
  }
  .events-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
  }
  .events-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13, 13, 13, 0.35) 0%,
      rgba(13, 13, 13, 0.8) 100%
    );
  }
  .events-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 2.5rem;
    width: 100%;
  }
  .hero-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
  }
  .hero-breadcrumb a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.15s;
  }
  .hero-breadcrumb a:hover {
    color: var(--color-gem-gold);
  }
  .events-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 600;
    color: white;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .events-hero-title em {
    font-style: italic;
    color: var(--color-gem-gold-light);
  }
  .events-hero-sub {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.9375rem;
  }

  .cat-carousel-bar {
    background: white;
    border-bottom: 1px solid var(--color-gem-border);
    overflow-x: auto;
    scrollbar-width: none;
    position: sticky;
    top: 64px;
    z-index: 40;
  }
  .cat-carousel-bar::-webkit-scrollbar {
    display: none;
  }
  .cat-carousel-track {
    display: flex;
    gap: 0.375rem;
    padding: 0.75rem 2rem;
    width: max-content;
    min-width: 100%;
  }
  .cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    border: 1.5px solid var(--color-gem-border);
    color: var(--color-gem-text-muted);
    background: white;
    transition: all 0.15s;
  }
  .cat-pill:hover {
    border-color: var(--color-gem-gold);
    color: var(--color-gem-gold);
  }
  .cat-pill-active {
    background: var(--color-gem-gold);
    border-color: var(--color-gem-gold);
    color: var(--color-gem-dark);
    font-weight: 600;
  }

  .explore-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
    padding-top: 2rem;
    padding-bottom: 4rem;
    align-items: start;
  }
  @media (max-width: 1024px) {
    .explore-layout {
      grid-template-columns: 1fr;
    }
    .explore-sidebar {
      display: none;
    }
  }
  .explore-sidebar {
    position: sticky;
    top: 120px;
  }
  .sidebar-inner {
    background: white;
    border-radius: 12px;
    border: 1.5px solid var(--color-gem-border);
    overflow: hidden;
  }
  .sidebar-section {
    padding: 1.25rem;
  }
  .sidebar-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gem-text-subtle);
    margin-bottom: 0.75rem;
  }
  .sidebar-divider {
    height: 1px;
