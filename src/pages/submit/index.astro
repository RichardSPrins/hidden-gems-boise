<script>
  // Category → subcategory dependency
  const categorySelect = document.getElementById(
    "categoryId"
  ) as HTMLSelectElement;
  const subcategorySelect = document.getElementById(
    "subcategoryId"
  ) as HTMLSelectElement;

  const subcategoryMap: Record<string, { id: string; name: string }[]> = {
    // populated from server data via inline script below
  };

  // Inject subcategory data from server
  const categories = JSON.parse(
    document.getElementById("categories-data")?.textContent ?? "[]"
  );
  categories.forEach((cat: any) => {
    subcategoryMap[cat.id] = cat.subcategories ?? [];
  });

  categorySelect?.addEventListener("change", () => {
    const catId = categorySelect.value;
    const subs = subcategoryMap[catId] ?? [];
    subcategorySelect.innerHTML = "";

    const defaultOpt = document.createElement("option");
    defaultOpt.value = "";
    defaultOpt.textContent =
      subs.length > 0 ? "Select a type…" : "No subtypes available";
    subcategorySelect.appendChild(defaultOpt);

    subs.forEach((sub) => {
      const opt = document.createElement("option");
      opt.value = sub.id;
      opt.textContent = sub.name;
      subcategorySelect.appendChild(opt);
    });
  });

  // Billing toggle
  const toggle = document.getElementById("billing-toggle") as HTMLButtonElement;
  const billingInput = document.getElementById(
    "billing-cycle-input"
  ) as HTMLInputElement;
  const monthlyPrices = document.querySelectorAll(".tier-price-monthly");
  const annualPrices = document.querySelectorAll(".tier-price-annual");

  toggle?.addEventListener("click", () => {
    const isAnnual = toggle.classList.toggle("active");
    toggle.setAttribute("aria-pressed", String(isAnnual));
    billingInput.value = isAnnual ? "annual" : "monthly";

    monthlyPrices.forEach(
      (el) => ((el as HTMLElement).style.display = isAnnual ? "none" : "")
    );
    annualPrices.forEach(
      (el) => ((el as HTMLElement).style.display = isAnnual ? "" : "none")
    );
  });

  // Form submission
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const errorWrap = document.getElementById("submit-error") as HTMLDivElement;
  const errorText = document.getElementById(
    "submit-error-text"
  ) as HTMLParagraphElement;
  const errorClaim = document.getElementById(
    "submit-error-claim"
  ) as HTMLAnchorElement;

  submitBtn?.addEventListener("click", async (e) => {
    e?.preventDefault();
    // Gather all form values
    const getValue = (id: string) =>
      (document.getElementById(id) as HTMLInputElement)?.value?.trim() ?? "";
    const getCheckedRadio = (name: string) =>
      (
        document.querySelector(
          `input[name="${name}"]:checked`
        ) as HTMLInputElement
      )?.value ?? "";

    const payload = {
      businessName: getValue("businessName"),
      categoryId: getValue("categoryId"),
      subcategoryId: getValue("subcategoryId"),
      website: getValue("website"),
      phone: getValue("phone"),
      email: getValue("email"),
      address: getValue("address"),
      city: getValue("city"),
      state: getValue("state"),
      zip: getValue("zip"),
      neighborhood: getValue("neighborhood"),
      bio: getValue("bio"),
      pricePoint: getValue("pricePoint"),
      tier: getCheckedRadio("tier"),
      billingCycle: getValue("billing-cycle-input"),
      ownerName: getValue("ownerName"),
      ownerEmail: getValue("ownerEmail"),
      notes: getValue("notes"),
    };

    // Basic client-side required check
    if (
      !payload.businessName ||
      !payload.categoryId ||
      !payload.email ||
      !payload.ownerName ||
      !payload.ownerEmail ||
      !payload.tier
    ) {
      errorWrap.classList.remove("hidden");
      errorText.textContent =
        "Please fill in all required fields and select a plan.";
      errorClaim.classList.add("hidden");
      errorWrap.scrollIntoView({ behavior: "smooth", block: "center" });

      //hide error after 5 seconds
      setTimeout(() => {
        errorWrap.classList.add("hidden");
      }, 5000);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting…";
    errorWrap.classList.add("hidden");

    try {
      const res = await fetch("/api/submissions", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const data = await res.json();

      if (res.ok) {
        window.location.href = "/submit/thank-you";
        return;
      }

      // Handle duplicate errors
      errorWrap.classList.remove("hidden");
      errorText.textContent =
        data.message ?? "Something went wrong. Please try again.";

      if (data.error === "duplicate_business" && data.slug) {
        errorClaim.href = `/listings/${data.slug}`;
        errorClaim.textContent = "View the existing listing →";
        errorClaim.classList.remove("hidden");
      } else {
        errorClaim.classList.add("hidden");
      }

      errorWrap.scrollIntoView({ behavior: "smooth", block: "center" });
    } catch {
      errorWrap.classList.remove("hidden");
      errorText.textContent = "Something went wrong. Please try again.";
      errorClaim.classList.add("hidden");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Submit Your Listing →";
    }
  });
</script>

<!-- Inject category data for subcategory JS -->
<script
  id="categories-data"
  type="application/json"
  set:html={JSON.stringify(categories)}
/>
